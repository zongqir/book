---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getHomeData, loadSiteIndex } from "../lib/content";
import { getContentSource } from "../lib/content-source";
import { toInternalHref } from "../lib/internal-links";

const { books, quotes } = getHomeData();
const firstBook = books[0];
const siteIndex = loadSiteIndex();
const contentSource = getContentSource();
const pagesById = new Map(siteIndex.pages.map((page) => [page.id, page]));

function stripWrappingQuotes(value: string) {
  return value.replace(/^[\"'“”‘’«»「」『』]+|[\"'“”‘’«»「」『』]+$/g, "");
}

function markdownToPlainText(markdown: string) {
  return markdown
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/\{\{<[\s\S]*?>\}\}/g, " ")
    .replace(/!\[([^\]]*)\]\([^)]+\)/g, "$1")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/<[^>]+>/g, " ")
    .replace(/^[>#*\-\d.\s]+/gm, "")
    .replace(/`([^`]+)`/g, "$1")
    .replace(/[_*~]/g, "")
    .replace(/\r?\n+/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function clampText(value: string, maxLength = 210) {
  const text = value.trim();
  if (text.length <= maxLength) return text;
  return text.slice(0, maxLength).trimEnd() + "...";
}

function extractLeadParagraph(markdown: string) {
  const blocks = markdown
    .split(/\r?\n\s*\r?\n/)
    .map((block) => block.trim())
    .filter(Boolean);

  const candidates: string[] = [];

  for (const block of blocks) {
    if (/^(#|\{\{<|!?\[|<|[-*]\s|\d+\.\s)/.test(block)) continue;
    const text = markdownToPlainText(block);
    if (text.length < 18) continue;
    candidates.push(text);
    if (candidates.length >= 2) break;
  }

  if (candidates.length) {
    return candidates.join(" ");
  }

  return markdownToPlainText(markdown);
}

function getWhyReadLead(pageId?: string) {
  if (!pageId) return "";
  try {
    const markdown = contentSource.loadPageMarkdown(pageId);
    return clampText(extractLeadParagraph(markdown));
  } catch (_error) {
    return "";
  }
}

function getBookEntry(bookId: string, fallbackUrl: string) {
  const whyReadPage = siteIndex.pages.find((page) => page.book_id === bookId && String(page.slot ?? "").startsWith("00"));
  return {
    url: whyReadPage?.url ?? fallbackUrl,
    whyRead: getWhyReadLead(whyReadPage?.id),
  };
}

const libraryHref = toInternalHref("/library/");
const bookEntryById = new Map(books.map((book) => [book.id, getBookEntry(book.id, book.url)]));
const whyReadSeed = Object.fromEntries(Array.from(bookEntryById.entries()).map(([bookId, entry]) => [bookId, entry.whyRead]));
const normalizedQuotes = quotes
  .map((quote) => {
    const page = pagesById.get(quote.page_id);
    return {
      bookId: page?.book_id ?? "",
      quote: stripWrappingQuotes(quote.quote || ""),
    };
  })
  .filter((quote) => quote.bookId);
const quoteCountByBookId = new Map<string, number>();
normalizedQuotes.forEach((quote) => {
  quoteCountByBookId.set(quote.bookId, (quoteCountByBookId.get(quote.bookId) ?? 0) + 1);
});
const homepageBooks = books.filter((book) => {
  const entry = bookEntryById.get(book.id);
  return Boolean(entry && entry.whyRead && (quoteCountByBookId.get(book.id) ?? 0) > 0);
});
const featuredBook = homepageBooks[0] ?? firstBook;
const firstBookEntry = featuredBook ? bookEntryById.get(featuredBook.id) : null;
const firstQuote = featuredBook ? normalizedQuotes.find((quote) => quote.bookId === featuredBook.id) ?? null : null;
---

<BaseLayout
  isHome={true}
  isLibrary={false}
  description="随机一本到，直接开读。"
  canonicalPath="/"
  ogTitle="今天读什么"
  ogDescription="随机一本到，直接开读。"
>
  <div class="page-stack home-page">
    <section class="home-single-stage">
      <article class="home-cover-card" aria-live="polite">
        <div class="home-cover-copy">
          <h1 class="home-cover-title" id="home-cover-title">{featuredBook?.title ?? "随机一本到"}</h1>
          <p class="home-cover-summary" id="home-cover-summary">{featuredBook?.summary ?? "先打开一页，再决定今天往哪走。"}</p>
        </div>

        <div class="home-cover-why" id="home-cover-why" hidden={!firstBookEntry?.whyRead}>
          <p id="home-cover-why-copy">{firstBookEntry?.whyRead ?? ""}</p>
        </div>

        <div class="home-cover-quote" id="home-cover-quote" hidden={!firstQuote}>
          <p class="home-cover-quote-text" id="home-cover-quote-text">{firstQuote?.quote ?? ""}</p>
        </div>

        <div class="home-cover-actions">
          <button class="tool-switch" type="button" id="home-cover-shuffle-book">换书</button>
          <button class="tool-switch" type="button" id="home-cover-shuffle-quote">换句子</button>
          <a class="btn" id="home-cover-open" href={firstBookEntry?.url ?? featuredBook?.url ?? libraryHref}>打开本书</a>
        </div>
      </article>
    </section>
  </div>

  <script type="application/json" id="home-why-read-seed">{JSON.stringify(whyReadSeed)}</script>

  <script is:inline>
    (function () {
      var BOOK_STATUS_STORAGE_KEY = "book:statuses:v1";
      var FAVORITE_CURATION_STATE = "favorite";
      var DEFAULT_READ_STATE = "unread";
      var DEFAULT_CURATION_STATE = "normal";
      var contentSource = "/data/site-content.json";
      var whyReadSeedNode = document.getElementById("home-why-read-seed");
      var whyReadByBookId = {};

      try {
        if (whyReadSeedNode && whyReadSeedNode.textContent) {
          whyReadByBookId = JSON.parse(whyReadSeedNode.textContent);
        }
      } catch (_error) {
        whyReadByBookId = {};
      }

      var books = [];
      var currentBook = 0;
      var currentQuote = 0;

      var coverTitle = document.getElementById("home-cover-title");
      var coverSummary = document.getElementById("home-cover-summary");
      var coverWhy = document.getElementById("home-cover-why");
      var coverWhyCopy = document.getElementById("home-cover-why-copy");
      var coverQuote = document.getElementById("home-cover-quote");
      var coverQuoteText = document.getElementById("home-cover-quote-text");
      var coverOpen = document.getElementById("home-cover-open");
      var shuffleBook = document.getElementById("home-cover-shuffle-book");
      var shuffleQuote = document.getElementById("home-cover-shuffle-quote");

      function stripWrappingQuotes(value) {
        return String(value || "").replace(/^[\"'“”‘’«»「」『』]+|[\"'“”‘’«»「」『』]+$/g, "");
      }

      function readBookStatusOverrides() {
        try {
          var raw = window.localStorage.getItem(BOOK_STATUS_STORAGE_KEY);
          if (!raw) return {};
          var parsed = JSON.parse(raw);
          if (!parsed || typeof parsed !== "object" || !parsed.books || typeof parsed.books !== "object") {
            return {};
          }
          return parsed.books;
        } catch (_error) {
          return {};
        }
      }

      function normalizeReadState(value) {
        return value === "reading" || value === "read" ? value : DEFAULT_READ_STATE;
      }

      function normalizeCurationState(value) {
        return value === "favorite" || value === "uninterested" ? value : DEFAULT_CURATION_STATE;
      }

      function resolveBookStates(item, overrides) {
        var override = overrides && item && item.id ? overrides[item.id] : null;
        return {
          readState: normalizeReadState(override && override.read_state ? override.read_state : item.read_state),
          curationState: normalizeCurationState(
            override && override.curation_state ? override.curation_state : item.curation_state,
          ),
        };
      }

      function getCurrentBook() {
        return books[currentBook] || null;
      }

      function setQuoteState(current, quote) {
        var hasQuote = Boolean(current && quote);
        if (coverQuote) coverQuote.hidden = !hasQuote;
        if (shuffleQuote instanceof HTMLButtonElement) {
          shuffleQuote.disabled = !current || !current.quotes || current.quotes.length <= 1;
        }
        if (!hasQuote) return;
        if (coverQuoteText) coverQuoteText.textContent = quote.quote || "";
      }

      function renderQuote(index) {
        var current = getCurrentBook();
        var currentQuotes = current && Array.isArray(current.quotes) ? current.quotes : [];
        if (!currentQuotes.length) {
          currentQuote = 0;
          setQuoteState(current, null);
          return;
        }

        currentQuote = ((index % currentQuotes.length) + currentQuotes.length) % currentQuotes.length;
        var quote = currentQuotes[currentQuote];
        if (!quote) {
          setQuoteState(current, null);
          return;
        }
        setQuoteState(current, quote);
      }

      function randomQuote(excludeCurrent) {
        var current = getCurrentBook();
        var currentQuotes = current && Array.isArray(current.quotes) ? current.quotes : [];
        if (!currentQuotes.length) return 0;
        if (currentQuotes.length === 1) return 0;
        if (!excludeCurrent) return Math.floor(Math.random() * currentQuotes.length);
        var next = currentQuote;
        while (next === currentQuote) {
          next = Math.floor(Math.random() * currentQuotes.length);
        }
        return next;
      }

      function renderBook(index) {
        if (!books.length) return;
        currentBook = ((index % books.length) + books.length) % books.length;
        var current = books[currentBook];
        if (!current) return;

        if (coverTitle) coverTitle.textContent = current.title || "未命名";
        if (coverSummary) coverSummary.textContent = current.summary || "";
        if (coverWhyCopy) coverWhyCopy.textContent = current.whyRead || "";
        if (coverWhy) coverWhy.hidden = !current.whyRead;
        if (coverOpen) coverOpen.href = current.entryUrl || current.url || "#";
        renderQuote(randomQuote(false));
      }

      function randomBook(excludeCurrent) {
        if (!books.length) return 0;
        if (books.length === 1) return 0;

        var pool = [];
        books.forEach(function (book, index) {
          if (excludeCurrent && index === currentBook) return;
          pool.push(index);
          if (book && book.curationState === FAVORITE_CURATION_STATE) {
            pool.push(index);
          }
        });

        if (!pool.length) return currentBook;
        return pool[Math.floor(Math.random() * pool.length)];
      }

      if (shuffleBook instanceof HTMLButtonElement) {
        shuffleBook.addEventListener("click", function () {
          renderBook(randomBook(true));
        });
      }

      if (shuffleQuote instanceof HTMLButtonElement) {
        shuffleQuote.addEventListener("click", function () {
          renderQuote(randomQuote(true));
        });
      }

      fetch(contentSource)
        .then(function (response) {
          if (!response.ok) throw new Error("Failed to load content index");
          return response.json();
        })
        .then(function (payload) {
          var statusOverrides = readBookStatusOverrides();
          var pagesById = {};
          var pageGroups = {};
          var quoteGroups = {};

          if (Array.isArray(payload.pages)) {
            payload.pages.forEach(function (page) {
              if (!page || !page.id) return;
              pagesById[page.id] = page;
              if (!page.book_id) return;
              if (!pageGroups[page.book_id]) pageGroups[page.book_id] = [];
              pageGroups[page.book_id].push(page);
            });
          }

          if (Array.isArray(payload.quotes)) {
            payload.quotes.forEach(function (item) {
              if (!item) return;
              var page = item.page_id ? pagesById[item.page_id] : null;
              var bookId = page && page.book_id ? page.book_id : "";
              if (!bookId) return;
              if (!quoteGroups[bookId]) quoteGroups[bookId] = [];
              quoteGroups[bookId].push({
                quote: stripWrappingQuotes(item.quote || ""),
              });
            });
          }

          books = Array.isArray(payload.books)
            ? payload.books
                .map(function (item) {
                  var states = resolveBookStates(item, statusOverrides);
                  return {
                    item: item,
                    readState: states.readState,
                    curationState: states.curationState,
                  };
                })
                .filter(function (item) {
                  return item.curationState !== "uninterested";
                })
                .map(function (item) {
                  var source = item.item;
                  var pages = pageGroups[source.id] || [];
                  var quotePool = quoteGroups[source.id] || [];
                  var whyReadPage = pages.find(function (page) {
                    return String(page.slot || "").indexOf("00") === 0;
                  });
                  if (!whyReadPage) return null;
                  if (!whyReadByBookId[source.id]) return null;
                  if (!quotePool.length) return null;
                  return {
                    id: source.id,
                    title: source.title || "未命名",
                    url: source.url || "#",
                    entryUrl: whyReadPage && whyReadPage.url ? whyReadPage.url : (source.url || "#"),
                    summary: source.summary || "",
                    whyRead: whyReadByBookId[source.id] || "",
                    quotes: quotePool,
                    readState: item.readState,
                    curationState: item.curationState,
                  };
                })
                .filter(Boolean)
            : [];

          if (books.length) {
            renderBook(randomBook(false));
          }
        })
        .catch(function () {});
    })();
  </script>
</BaseLayout>
