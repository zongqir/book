---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { toInternalHref } from "../../lib/internal-links";

const libraryHref = toInternalHref("/library/");
const notesHref = toInternalHref("/notes/");
---

<BaseLayout
  title="书架"
  description="把最近阅读、在读书和收藏书放在一起，回来先接着读。"
  canonicalPath="/shelf/"
  ogDescription="把最近阅读、在读书和收藏书放在一起，回来先接着读。"
  isShelf={true}
>
  <div class="page-stack shelf-dashboard">
    <section class="library-panel shelf-stage">
      <div class="shelf-hero">
        <div class="shelf-hero-copy">
          <p class="hero-kicker">书架</p>
          <h1>回来先接着读</h1>
          <p class="shelf-lead">这里不做管理，只把你最可能马上打开的书放在前面。</p>
        </div>
        <div class="shelf-hero-actions">
          <a class="btn" href={libraryHref}>去目录找书</a>
          <a class="tool-switch" href={notesHref}>打开个人管理</a>
        </div>
      </div>
    </section>

    <div class="shelf-stage-grid">
      <section class="content-card shelf-spotlight-card">
        <div class="section-head shelf-section-head">
          <div>
            <p class="eyebrow">继续阅读</p>
            <h2>最近打开的书</h2>
          </div>
        </div>

        <div class="shelf-recent-list" id="shelf-last-visit"></div>

        <div class="notes-empty personal-empty shelf-empty" id="shelf-last-visit-empty" hidden>
          <h2>这里还没有最近阅读</h2>
          <p>先随便打开一本书，或者进入一篇文章，书架下次就能直接把你接回来。</p>
        </div>
      </section>

      <section class="content-card shelf-reading-card">
        <div class="section-head shelf-section-head">
          <div>
            <p class="eyebrow">在读</p>
            <h2>现在还在推进的书</h2>
          </div>
        </div>

        <div class="shelf-book-list" id="shelf-reading-results"></div>
        <div class="notes-empty personal-empty shelf-empty" id="shelf-reading-empty" hidden>
          <h2>还没有标记在读的书</h2>
          <p>在书页把阅读进度切到“在读”，这本书就会出现在书架上。</p>
        </div>
      </section>
    </div>

    <section class="content-card shelf-favorites-card">
      <div class="section-head shelf-section-head">
        <div>
          <p class="eyebrow">收藏书</p>
          <h2>想反复回来的几本</h2>
        </div>
        <a class="tool-switch tool-switch--compact" href={notesHref}>去个人看全部收藏</a>
      </div>

      <div class="shelf-favorite-grid" id="shelf-favorite-results"></div>
      <div class="notes-empty personal-empty shelf-empty" id="shelf-favorite-empty" hidden>
        <h2>还没有收藏的书</h2>
        <p>在任意书页点一下爱心，书架里就会多一层“常回来”的感觉。</p>
      </div>
    </section>
  </div>

  <script is:inline>
    const BOOK_STATUS_STORAGE_KEY = "book:statuses:v1";
    const RECENT_BOOK_VISITS_STORAGE_KEY = "book:recent-books:v1";
    const libraryHref = {JSON.stringify(libraryHref)};

    const lastVisitNode = document.getElementById("shelf-last-visit");
    const lastVisitEmptyNode = document.getElementById("shelf-last-visit-empty");
    const readingResultsNode = document.getElementById("shelf-reading-results");
    const readingEmptyNode = document.getElementById("shelf-reading-empty");
    const favoriteResultsNode = document.getElementById("shelf-favorite-results");
    const favoriteEmptyNode = document.getElementById("shelf-favorite-empty");

    const state = {
      booksById: new Map(),
      readingBooks: [],
      favoriteBooks: [],
      recentBooks: [],
    };

    function readBookStatuses() {
      try {
        const raw = window.localStorage.getItem(BOOK_STATUS_STORAGE_KEY);
        if (!raw) return {};
        const parsed = JSON.parse(raw);
        if (!parsed || typeof parsed !== "object" || !parsed.books || typeof parsed.books !== "object") {
          return {};
        }
        return parsed.books;
      } catch (error) {
        return {};
      }
    }

    function readRecentBooks() {
      try {
        const raw = window.localStorage.getItem(RECENT_BOOK_VISITS_STORAGE_KEY);
        if (!raw) return [];
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return [];
        return parsed.filter((item) => (
          item
          && typeof item.bookId === "string"
          && item.bookId
          && typeof item.title === "string"
          && typeof item.bookUrl === "string"
          && typeof item.url === "string"
          && typeof item.context === "string"
          && typeof item.summary === "string"
          && typeof item.updatedAt === "string"
        ));
      } catch (error) {
        return [];
      }
    }

    function escapeHtml(value) {
      return String(value || "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    function escapeAttribute(value) {
      return escapeHtml(value).replaceAll("\n", " ");
    }

    function formatTime(value) {
      if (!value) return "";
      const parsed = new Date(value);
      if (Number.isNaN(parsed.getTime())) return "";
      return new Intl.DateTimeFormat("zh-CN", {
        year: "numeric",
        month: "numeric",
        day: "numeric",
        hour: "2-digit",
        minute: "2-digit",
      }).format(parsed);
    }

    function compareByUpdatedAtDesc(left, right) {
      return String(right.updated_at || "").localeCompare(String(left.updated_at || ""))
        || String(left.title || "").localeCompare(String(right.title || ""));
    }

    function refreshCollections() {
      state.recentBooks = readRecentBooks();
      const bookStatuses = readBookStatuses();
      const booksWithStatus = Array.from(state.booksById.values())
        .map((book) => ({
          ...book,
          ...(bookStatuses[book.id] || {}),
        }))
        .sort(compareByUpdatedAtDesc);

      state.readingBooks = booksWithStatus.filter((book) => book.read_state === "reading");
      state.favoriteBooks = booksWithStatus.filter((book) => book.curation_state === "favorite");
    }

    function renderLastVisit() {
      if (!(lastVisitNode instanceof HTMLElement) || !(lastVisitEmptyNode instanceof HTMLElement)) return;

      if (!state.recentBooks.length) {
        lastVisitNode.innerHTML = "";
        lastVisitNode.hidden = true;
        lastVisitEmptyNode.hidden = false;
        return;
      }

      lastVisitEmptyNode.hidden = true;
      lastVisitNode.hidden = false;
      lastVisitNode.innerHTML = state.recentBooks
        .slice(0, 5)
        .map((book, index) => `
          <article class="shelf-recent-item${index === 0 ? " is-primary" : ""}">
            <div class="shelf-recent-topline">
              <span class="meta-chip">继续阅读</span>
              <time class="shelf-recent-time" datetime="${escapeAttribute(book.updatedAt)}">${escapeHtml(formatTime(book.updatedAt) || "刚刚")}</time>
            </div>
            <h3>${escapeHtml(book.title || "最近阅读")}</h3>
            <p class="shelf-recent-context">${escapeHtml(book.context || "目录里最近打开的内容")}</p>
            <p class="shelf-recent-summary">${escapeHtml(book.summary || "回到刚才停下的位置。")}</p>
            <div class="shelf-recent-actions">
              <a class="${index === 0 ? "btn btn-shelf-primary" : "tool-switch tool-switch--compact"}" href="${escapeAttribute(book.url || book.bookUrl || libraryHref)}">继续打开</a>
              ${book.url && book.bookUrl && book.url !== book.bookUrl ? `<a class="tool-switch tool-switch--compact" href="${escapeAttribute(book.bookUrl)}">打开书页</a>` : ""}
            </div>
          </article>
        `)
        .join("");
    }

    function renderReadingBooks() {
      if (!(readingResultsNode instanceof HTMLElement)) return;

      if (!state.readingBooks.length) {
        readingResultsNode.innerHTML = "";
        if (readingEmptyNode instanceof HTMLElement) readingEmptyNode.hidden = false;
        return;
      }

      if (readingEmptyNode instanceof HTMLElement) readingEmptyNode.hidden = true;
      readingResultsNode.innerHTML = state.readingBooks
        .map((book) => `
          <article class="personal-card shelf-book-card">
            <div class="personal-card-topline">
              <span class="meta-chip">${escapeHtml(book.section_title || "未分类")}</span>
              <span class="meta-chip">在读</span>
              ${book.curation_state === "favorite" ? '<span class="meta-chip">已收藏</span>' : ""}
            </div>
            <h3>${escapeHtml(book.title)}</h3>
            <p>${escapeHtml(book.summary || "这本书目前还没有摘要。")}</p>
            <div class="personal-card-actions">
              <a class="btn btn-shelf-primary" href="${escapeAttribute(book.url || "#")}">继续阅读</a>
            </div>
          </article>
        `)
        .join("");
    }

    function renderFavoriteBooks() {
      if (!(favoriteResultsNode instanceof HTMLElement)) return;

      const visibleFavorites = state.favoriteBooks.slice(0, 6);
      if (!visibleFavorites.length) {
        favoriteResultsNode.innerHTML = "";
        if (favoriteEmptyNode instanceof HTMLElement) favoriteEmptyNode.hidden = false;
        return;
      }

      if (favoriteEmptyNode instanceof HTMLElement) favoriteEmptyNode.hidden = true;
      favoriteResultsNode.innerHTML = visibleFavorites
        .map((book) => `
          <article class="personal-card shelf-favorite-card">
            <div class="personal-card-topline">
              <span class="meta-chip">${escapeHtml(book.section_title || "未分类")}</span>
              <span class="meta-chip">收藏</span>
            </div>
            <h3>${escapeHtml(book.title)}</h3>
            <p>${escapeHtml(book.summary || "这本书目前还没有摘要。")}</p>
            <div class="personal-card-actions">
              <a class="tool-switch tool-switch--compact" href="${escapeAttribute(book.url || "#")}">打开这本书</a>
            </div>
          </article>
        `)
        .join("");
    }

    function render() {
      renderLastVisit();
      renderReadingBooks();
      renderFavoriteBooks();
    }

    async function loadIndex() {
      try {
        const response = await fetch("/data/site-content.json", { cache: "force-cache" });
        if (!response.ok) throw new Error("Failed to load site content");
        const payload = await response.json();
        const books = Array.isArray(payload.books) ? payload.books : [];
        books.forEach((book) => {
          if (book && book.id) state.booksById.set(book.id, book);
        });
      } catch (error) {
        console.error("Failed to load shelf index", error);
      } finally {
        refreshCollections();
      }
    }

    window.addEventListener("book-status:changed", function () {
      refreshCollections();
      render();
    });

    window.addEventListener("storage", function (event) {
      if (event.key === BOOK_STATUS_STORAGE_KEY || event.key === RECENT_BOOK_VISITS_STORAGE_KEY) {
        refreshCollections();
        render();
      }
    });

    Promise.allSettled([loadIndex()]).then(function () {
      refreshCollections();
      render();
    });
  </script>
</BaseLayout>
