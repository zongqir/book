---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLibraryIndex } from "../../lib/content";

const sections = getLibraryIndex().filter((section) => section.key !== "02_专业技术");
---

<BaseLayout title="目录" isLibrary={true}>
  <div class="page-stack">
    <section class="library-panel">
      <div class="library-hero">
        <p class="hero-kicker">Library index</p>
        <h1>全部分类</h1>
        <p>从一个主题进去，再在书和文稿里慢慢走。</p>
      </div>
    </section>

    <section class="library-sections">
      {sections.map((section) => (
        <article class="library-index-card">
          <a href={section.url}>
            <div class="card-topline">
              <span class="section-index">{section.key.slice(0, 2)}</span>
              <span class="preview-pill">{section.book_count} 本书</span>
            </div>
            <h3>{section.title}</h3>
            <p class="section-volume">
              <strong>{section.page_count}</strong>
              <span>篇文稿</span>
            </p>
            <div class="library-index-preview">
              {section.books.slice(0, 3).map((book) => (
                <span class="preview-item">{book.title}</span>
              ))}
            </div>
            <div class="section-enter">
              <span>打开分类</span>
              <span>→</span>
            </div>
          </a>
        </article>
      ))}
    </section>
  </div>
</BaseLayout>
