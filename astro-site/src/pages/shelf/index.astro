---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { toInternalHref } from "../../lib/internal-links";

const libraryHref = toInternalHref("/library/");
---

<BaseLayout
  title="书架"
  description="把最近打开的书放在前面，回来先接着读。"
  canonicalPath="/shelf/"
  ogDescription="把最近打开的书放在前面，回来先接着读。"
  isShelf={true}
>
  <div class="page-stack shelf-dashboard">
    <section class="library-panel shelf-stage">
      <div class="shelf-hero">
        <div class="shelf-hero-copy">
          <p class="hero-kicker">书架</p>
          <h1>回来先接着读</h1>
          <p class="shelf-lead">这里不做管理，只把你最可能马上打开的书放在前面。</p>
        </div>
        <div class="shelf-hero-actions">
          <a class="btn" href={libraryHref}>去分类找书</a>
        </div>
      </div>
    </section>

    <div class="shelf-stage-grid">
      <section class="content-card shelf-spotlight-card">
        <div class="section-head shelf-section-head">
          <div>
            <p class="eyebrow">继续阅读</p>
            <h2>最近打开的书</h2>
          </div>
        </div>

        <div class="shelf-recent-list" id="shelf-last-visit"></div>

        <div class="notes-empty personal-empty shelf-empty" id="shelf-last-visit-empty" hidden>
          <h2>这里还没有最近阅读</h2>
          <p>先随便打开一本书，或者进入一篇文章，书架下次就能直接把你接回来。</p>
        </div>
      </section>
    </div>
  </div>

  <script>
    import { readRecentBookVisits } from "../../lib/personal-preferences";

    const RECENT_BOOK_VISITS_STORAGE_KEY = "book:recent-books:v1";
    const libraryHref = "/library/";

    const lastVisitNode = document.getElementById("shelf-last-visit");
    const lastVisitEmptyNode = document.getElementById("shelf-last-visit-empty");

    const state = {
      recentBooks: [],
    };

    function readRecentBooks() {
      return readRecentBookVisits();
    }

    function escapeHtml(value) {
      return String(value || "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    function escapeAttribute(value) {
      return escapeHtml(value).replaceAll("\n", " ");
    }

    function formatTime(value) {
      if (!value) return "";
      const parsed = new Date(value);
      if (Number.isNaN(parsed.getTime())) return "";
      return new Intl.DateTimeFormat("zh-CN", {
        year: "numeric",
        month: "numeric",
        day: "numeric",
        hour: "2-digit",
        minute: "2-digit",
      }).format(parsed);
    }

    function refreshCollections() {
      state.recentBooks = readRecentBooks();
    }

    function renderLastVisit() {
      if (!(lastVisitNode instanceof HTMLElement) || !(lastVisitEmptyNode instanceof HTMLElement)) return;

      if (!state.recentBooks.length) {
        lastVisitNode.innerHTML = "";
        lastVisitNode.hidden = true;
        lastVisitEmptyNode.hidden = false;
        return;
      }

      lastVisitEmptyNode.hidden = true;
      lastVisitNode.hidden = false;
      lastVisitNode.innerHTML = state.recentBooks
        .slice(0, 5)
        .map((book, index) => `
          <article class="shelf-recent-item${index === 0 ? " is-primary" : ""}">
            <div class="shelf-recent-topline">
              <span class="meta-chip">继续阅读</span>
              <time class="shelf-recent-time" datetime="${escapeAttribute(book.updatedAt)}">${escapeHtml(formatTime(book.updatedAt) || "刚刚")}</time>
            </div>
            <h3>${escapeHtml(book.title || "最近阅读")}</h3>
            <p class="shelf-recent-context">${escapeHtml(book.context || "分类里最近打开的内容")}</p>
            <p class="shelf-recent-summary">${escapeHtml(book.summary || "回到刚才停下的位置。")}</p>
            <div class="shelf-recent-actions">
              <a class="${index === 0 ? "btn btn-shelf-primary" : "tool-switch tool-switch--compact"}" href="${escapeAttribute(book.url || book.bookUrl || libraryHref)}">继续打开</a>
              ${book.url && book.bookUrl && book.url !== book.bookUrl ? `<a class="tool-switch tool-switch--compact" href="${escapeAttribute(book.bookUrl)}">打开书页</a>` : ""}
            </div>
          </article>
        `)
        .join("");
    }

    function render() {
      renderLastVisit();
    }

    window.addEventListener("storage", function (event) {
      if (event.key === RECENT_BOOK_VISITS_STORAGE_KEY) {
        refreshCollections();
        render();
      }
    });

    window.addEventListener("recent-books:changed", function () {
      refreshCollections();
      render();
    });

    refreshCollections();
    render();
  </script>
</BaseLayout>
