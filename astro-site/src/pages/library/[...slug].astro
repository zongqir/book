---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllLibrarySlugs, getNodeBySlug } from "../../lib/content";
import { toInternalHref } from "../../lib/internal-links";
import { buildLibraryOgImagePath, describeNodeForOg } from "../../lib/og-image";

export async function getStaticPaths() {
  return getAllLibrarySlugs().map((slugParts) => ({
    params: { slug: slugParts.join("/") },
    props: { slugParts },
  }));
}

const { slugParts } = Astro.props;
const parts = Array.isArray(slugParts) ? slugParts : String(slugParts).split("/");
const node = getNodeBySlug(parts);

if (!node) {
  throw new Error(`Missing library node for ${parts.join("/")}`);
}


const metaDescription =
  node.kind === "section"
    ? `${node.title}分类下共 ${node.books.length} 本书，可以直接从书页往里读。`
    : node.kind === "book"
      ? (node.book.summary || `${node.book.section_title}分类下的《${node.book.title}》书页与文稿入口。`)
      : (node.page.summary || node.page.intent || `${node.book?.title || "这本书"}中的一篇文稿。`);
const canonicalPath = node.url;
const ogType = node.kind === "page" ? "article" : "website";
const ogImage = buildLibraryOgImagePath(parts);
const ogImageAlt = describeNodeForOg(node);
const libraryHref = toInternalHref("/library/");

function buildBreadcrumbContext(parts: string[]) {
  return parts.filter(Boolean).join(" / ");
}

function buildRecentBookMeta(node: ReturnType<typeof getNodeBySlug>) {
  if (node.kind === "book") {
    return {
      kind: "book",
      bookId: node.book.id,
      bookTitle: node.book.title,
      bookUrl: node.book.url,
      url: node.book.url,
      context: buildBreadcrumbContext([
        node.book.section_title,
        ...node.ancestorBooks.map((ancestor) => ancestor.title),
        node.book.title,
      ]),
      summary: node.book.summary || "",
    };
  }

  if (node.kind === "page" && node.book) {
    return {
      kind: "page",
      bookId: node.book.id,
      bookTitle: node.book.title,
      bookUrl: node.book.url,
      url: node.page.url,
      context: buildBreadcrumbContext([
        node.section?.title || "",
        ...node.ancestorBooks.map((ancestor) => ancestor.title),
        node.book.title,
        node.page.title,
      ]),
      summary: node.page.summary || node.page.intent || "",
    };
  }

  return null;
}

const recentBookMeta = buildRecentBookMeta(node);

function getReadStateLabel(value: "unread" | "reading" | "read") {
  if (value === "reading") return "在读";
  if (value === "read") return "已读";
  return "未读";
}

function getCurationStateLabel(value: "normal" | "favorite" | "uninterested") {
  if (value === "favorite") return "收藏";
  if (value === "uninterested") return "排除随机";
  return "保留";
}

function getBookStatusCopy(
  readState: "unread" | "reading" | "read",
  curationState: "normal" | "favorite" | "uninterested",
) {
  const progress =
    readState === "reading"
      ? "现在正在读。"
      : readState === "read"
        ? "这本已经读过。"
        : "这本还没开始。";
  const curation =
    curationState === "favorite"
      ? "它会继续参与随机，而且更常出现。"
      : curationState === "uninterested"
        ? "它会从首页随机里排除，但分类里还保留。"
        : "它会按普通权重参与随机。";
  return `${progress}${curation} 只保存在当前浏览器。`;
}
---

<BaseLayout
  title={node.title}
  description={metaDescription}
  canonicalPath={canonicalPath}
  ogDescription={metaDescription}
  ogType={ogType}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  isLibrary={true}
>
  {node.kind === "section" && (
    <div
      class="page-stack"
      data-current-library-node
      data-node-kind="section"
      data-url={node.url}
      data-title={node.title}
      data-context={node.title}
      data-summary=""
    >
      <section class="library-panel">
        <div class="page-intro page-intro--section">
          <nav class="breadcrumb" aria-label="breadcrumb">
            <a href={libraryHref}>分类</a>
            <span>/</span>
            <span>{node.title}</span>
          </nav>
          <div class="section-heading">
            <h1>{node.title}</h1>
          </div>
          <label class="field-control library-index-search library-index-search--section">
            <input
              id="section-library-search"
              type="search"
              placeholder={`搜${node.title}里的书名`}
              aria-label={`搜索 ${node.title} 分类里的书名`}
            />
          </label>
        </div>
      </section>

      <section class="section-shelf section-shelf--section-node">
        {node.books.map((book) => (
          <article class="book-card" data-section-book-item data-search-text={book.title}>
            <a href={book.url}>
              <h3>{book.title}</h3>
              {book.summary && <p>{book.summary}</p>}
              <div class="book-card-footer">
                {book.tags.slice(0, 3).map((tag) => <span class="tag-pill">{tag}</span>)}
              </div>
              <div class="section-enter">
                <span>进入这本书</span>
                <span>→</span>
              </div>
            </a>
          </article>
        ))}
      </section>
      <p class="preview-item preview-item--muted library-index-empty" id="section-library-empty" hidden>没搜到这类书，换个书名试试。</p>
    </div>
  )}

  {node.kind === "book" && (
    <div
      class="page-stack"
      data-current-library-node
      data-node-kind="book"
      data-book-id={recentBookMeta?.bookId || ""}
      data-book-title={recentBookMeta?.bookTitle || ""}
      data-book-url={recentBookMeta?.bookUrl || ""}
      data-url={recentBookMeta?.url || node.url}
      data-title={node.title}
      data-context={recentBookMeta?.context || node.title}
      data-summary={recentBookMeta?.summary || ""}
    >
      <section class="library-panel">
        <div class="page-intro page-intro--book">
          <nav class="breadcrumb" aria-label="breadcrumb">
            <a href={libraryHref}>分类</a>
            <span>/</span>
            <a href={toInternalHref(`/library/${node.book.section_key}/`)}>{node.book.section_title}</a>
            {node.ancestorBooks.map((ancestor) => (
              <>
                <span>/</span>
                <a href={ancestor.url}>{ancestor.title}</a>
              </>
            ))}
            <span>/</span>
            <span>{node.title}</span>
          </nav>
          <h1>{node.title}</h1>
          {node.book.summary && <p>{node.book.summary}</p>}
          <div class="detail-line">
            <span class="meta-chip">{node.pages.length} 个入口</span>
            {node.childBooks.length > 0 && <span class="meta-chip">{node.childBooks.length} 个子目录</span>}
            <span class="meta-chip">{node.book.section_title}</span>
            {node.book.tags.slice(0, 4).map((tag) => <span class="meta-chip">{tag}</span>)}
            <button
              class="favorite-icon-button"
              type="button"
              data-favorite-toggle
              data-favorite-kind="book"
              data-book-id={node.book.id}
              data-default-curation-state={node.book.curation_state}
              aria-pressed={node.book.curation_state === "favorite" ? "true" : "false"}
              aria-label={`收藏《${node.book.title}》`}
              title="收藏这本书"
            >
              <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="M10 16.9 4.3 11.5a3.8 3.8 0 0 1 0-5.4 3.74 3.74 0 0 1 5.3 0L10 6.5l.4-.4a3.74 3.74 0 0 1 5.3 0 3.8 3.8 0 0 1 0 5.4z"></path>
              </svg>
            </button>
            <div
              class="share-inline"
              data-share-area
              data-share-title={node.title}
              data-share-text={node.book.summary || `${node.book.section_title}里的《${node.book.title}》`}
              data-share-url={node.book.url}
              data-share-image={ogImage}
              data-share-filename={`${node.book.title}-share-card.svg`}
            >
              <button
                class="share-icon-button"
                type="button"
                data-share-toggle
                aria-haspopup="menu"
                aria-expanded="false"
                aria-label={`分享《${node.title}》`}
                title="分享这本书"
              >
                <svg viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M13 4.5h2.5v2.5"></path>
                  <path d="M8.25 11.75 15.5 4.5"></path>
                  <path d="M15.5 10v4.25A1.25 1.25 0 0 1 14.25 15.5h-8.5A1.25 1.25 0 0 1 4.5 14.25v-8.5A1.25 1.25 0 0 1 5.75 4.5H10"></path>
                </svg>
              </button>
              <div class="share-menu" data-share-menu hidden role="menu" aria-label="分享选项">
                <button class="share-menu-action" type="button" data-share-action="link" role="menuitem">分享链接</button>
                <button class="share-menu-action" type="button" data-share-action="image" role="menuitem">分享卡片</button>
              </div>
              <span class="share-inline-feedback" data-share-feedback aria-live="polite"></span>
            </div>
          </div>
          <section
            class="book-status-toolbar"
            data-book-status-root
            data-book-id={node.book.id}
            data-default-read-state={node.book.read_state}
            data-default-curation-state={node.book.curation_state}
            data-read-state={node.book.read_state}
            data-curation-state={node.book.curation_state}
          >
            <div class="book-status-toolbar-head">
              <div>
                <p class="eyebrow">阅读管理</p>
                <p class="book-status-toolbar-copy" data-book-status-copy>{getBookStatusCopy(node.book.read_state, node.book.curation_state)}</p>
              </div>
              <div class="book-status-current">
                <button
                  class="meta-chip book-status-current-trigger"
                  type="button"
                  data-book-status-read-chip
                  data-book-status-cycle="read"
                  aria-label={`切换阅读进度，当前${getReadStateLabel(node.book.read_state)}`}
                  title="点一下切换阅读进度"
                >
                  阅读 · {getReadStateLabel(node.book.read_state)}
                </button>
                <button
                  class="meta-chip book-status-current-trigger"
                  type="button"
                  data-book-status-curation-chip
                  data-book-status-cycle="curation"
                  aria-label={`切换书单状态，当前${getCurationStateLabel(node.book.curation_state)}`}
                  title="点一下切换书单状态"
                >
                  书单 · {getCurationStateLabel(node.book.curation_state)}
                </button>
              </div>
            </div>
            <div class="book-status-toolbar-groups">
              <div class="book-status-group book-status-group--compact">
                <span class="book-status-label">阅读进度</span>
                <div class="book-status-options">
                  <button class="tool-switch tool-switch--compact" type="button" data-book-status-kind="read" data-book-status-value="unread">未读</button>
                  <button class="tool-switch tool-switch--compact" type="button" data-book-status-kind="read" data-book-status-value="reading">在读</button>
                  <button class="tool-switch tool-switch--compact" type="button" data-book-status-kind="read" data-book-status-value="read">已读</button>
                </div>
              </div>
              <div class="book-status-group book-status-group--compact">
                <span class="book-status-label">书单处理</span>
                <div class="book-status-options">
                  <button class="tool-switch tool-switch--compact" type="button" data-book-status-kind="curation" data-book-status-value="normal">保留</button>
                  <button class="tool-switch tool-switch--compact" type="button" data-book-status-kind="curation" data-book-status-value="favorite">收藏</button>
                  <button class="tool-switch tool-switch--compact" type="button" data-book-status-kind="curation" data-book-status-value="uninterested">排除随机</button>
                </div>
              </div>
            </div>
          </section>
          <div class="slot-rail">
            {node.pages.map((page) => (
              <a class="slot-link" href={page.url}>
                <span class="slot-link-no">{page.slot}</span>
                <strong>{page.title}</strong>
              </a>
            ))}
          </div>
        </div>
      </section>

      {node.childBooks.length > 0 && (
        <section class="page-stack compact-stack">
          <div class="section-head">
            <div>
              <h2>书内目录</h2>
            </div>
          </div>
          <div class="book-shelf">
            {node.childBooks.map((child) => (
              <article class="doc-card">
                <a href={child.url}>
                  <div class="card-topline">
                    <span class="slot-badge">目录</span>
                  </div>
                  <h3>{child.title}</h3>
                  {child.summary && <p>{child.summary}</p>}
                  <div class="doc-card-footer">
                    {child.tags.slice(0, 4).map((tag) => <span class="tag-pill">{tag}</span>)}
                  </div>
                  <div class="section-enter">
                    <span>打开目录</span>
                    <span>→</span>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </section>
      )}

      <section class="book-shelf">
        {node.pages.map((page) => (
          <article class="doc-card">
            <a href={page.url}>
              <div class="card-topline">
                <span class="slot-badge">{page.slot}</span>
              </div>
              <h3>{page.title}</h3>
              {page.summary && <p>{page.summary}</p>}
              <div class="doc-card-footer">
                {page.tags.slice(0, 4).map((tag) => <span class="tag-pill">{tag}</span>)}
              </div>
              <div class="section-enter">
                <span>打开文稿</span>
                <span>→</span>
              </div>
            </a>
          </article>
        ))}
      </section>

      {node.relatedBooks.length > 0 && (
        <section class="page-stack compact-stack">
          <div class="section-head">
            <div>
              <h2>这一类里还能接着读</h2>
            </div>
          </div>
          <div class="book-shelf">
            {node.relatedBooks.map((item) => (
              <article class="book-card">
                <a href={item.book.url}>
                  <div class="card-topline">
                    <span class="section-index">{item.book.section_title}</span>
                  </div>
                  <h3>{item.book.title}</h3>
                  {item.book.summary && <p>{item.book.summary}</p>}
                  <div class="book-card-footer">
                    {item.shared_tags.length > 0
                      ? item.shared_tags.slice(0, 3).map((tag) => <span class="tag-pill">{tag}</span>)
                      : item.book.tags.slice(0, 3).map((tag) => <span class="tag-pill">{tag}</span>)}
                  </div>
                  <div class="section-enter">
                    <span>继续这类书</span>
                    <span>→</span>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </section>
      )}
    </div>
  )}

  {node.kind === "page" && (
    <div
      class="page-stack"
      data-current-library-node
      data-node-kind="page"
      data-book-id={recentBookMeta?.bookId || ""}
      data-book-title={recentBookMeta?.bookTitle || ""}
      data-book-url={recentBookMeta?.bookUrl || ""}
      data-url={recentBookMeta?.url || node.url}
      data-title={node.page.title}
      data-context={recentBookMeta?.context || node.page.title}
      data-summary={recentBookMeta?.summary || ""}
    >
      <section class="library-panel">
        <div class="doc-hero doc-hero--page">
          <nav class="breadcrumb" aria-label="breadcrumb">
            <a href={libraryHref}>分类</a>
            {node.section && (
              <>
                <span>/</span>
                <a href={node.section.url}>{node.section.title}</a>
              </>
            )}
            {node.ancestorBooks.map((ancestor) => (
              <>
                <span>/</span>
                <a href={ancestor.url}>{ancestor.title}</a>
              </>
            ))}
            {node.book && (
              <>
                <span>/</span>
                <a href={node.book.url}>{node.book.title}</a>
              </>
            )}
          </nav>
          <h1 class="page-title">{node.page.title}</h1>
          {node.page.summary && <p class="doc-summary">{node.page.summary}</p>}
          <div class="doc-hero-actions">
            <button
              class="favorite-icon-button"
              type="button"
              data-favorite-toggle
              data-favorite-kind="page"
              data-page-id={node.page.id}
              data-page-title={node.page.title}
              data-page-url={node.page.url}
              data-page-summary={node.page.summary || node.page.intent || node.page.title}
              data-book-id={node.book?.id || ""}
              data-book-title={node.book?.title || ""}
              data-book-url={node.book?.url || ""}
              data-section-title={node.page.section_title}
              data-page-slot={node.page.slot}
              aria-pressed="false"
              aria-label={`收藏《${node.page.title}》`}
              title="收藏这篇文章"
            >
              <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="M10 16.9 4.3 11.5a3.8 3.8 0 0 1 0-5.4 3.74 3.74 0 0 1 5.3 0L10 6.5l.4-.4a3.74 3.74 0 0 1 5.3 0 3.8 3.8 0 0 1 0 5.4z"></path>
              </svg>
            </button>
            <div
              class="share-inline"
              data-share-area
              data-share-title={`${node.book?.title || "今天读什么"} · ${node.page.title}`}
              data-share-text={node.page.summary || node.page.intent || node.page.title}
              data-share-url={node.page.url}
              data-share-image={ogImage}
              data-share-filename={`${node.page.title}-share-card.svg`}
            >
              <button
                class="share-icon-button"
                type="button"
                data-share-toggle
                aria-haspopup="menu"
                aria-expanded="false"
                aria-label={`分享《${node.page.title}》`}
                title="分享这一页"
              >
                <svg viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M13 4.5h2.5v2.5"></path>
                  <path d="M8.25 11.75 15.5 4.5"></path>
                  <path d="M15.5 10v4.25A1.25 1.25 0 0 1 14.25 15.5h-8.5A1.25 1.25 0 0 1 4.5 14.25v-8.5A1.25 1.25 0 0 1 5.75 4.5H10"></path>
                </svg>
              </button>
              <div class="share-menu" data-share-menu hidden role="menu" aria-label="分享选项">
                <button class="share-menu-action" type="button" data-share-action="link" role="menuitem">分享链接</button>
                <button class="share-menu-action" type="button" data-share-action="image" role="menuitem">分享卡片</button>
              </div>
              <span class="share-inline-feedback" data-share-feedback aria-live="polite"></span>
            </div>
          </div>
        </div>
      </section>

      <div class="doc-grid doc-grid--reading">
        <article class="content-card content-card--reading">
          {node.headings.length > 0 && (
            <details class="toc-card toc-card--mobile toc-card--mobile-reading">
              <summary class="toc-summary">本页目录</summary>
              <ul class="toc-list">
                {node.headings
                  .filter((item) => item.level <= 2)
                  .map((heading) => (
                    <li>
                      <a href={`#${heading.id}`}>{heading.title}</a>
                    </li>
                  ))}
              </ul>
            </details>
          )}

          <section class="doc-content" data-reader-notes-root data-page-id={node.page.id} set:html={node.html} />

          {(node.previousPage || node.nextPage) && (
            <nav class="page-nav page-nav--reading" aria-label="继续阅读">
              {node.previousPage && (
                <a class="page-nav-card" href={node.previousPage.url}>
                  <span class="page-nav-label">上一页</span>
                  <strong>{node.previousPage.title}</strong>
                </a>
              )}
              {node.nextPage && (
                <a class="page-nav-card" href={node.nextPage.url}>
                  <span class="page-nav-label">下一页</span>
                  <strong>{node.nextPage.title}</strong>
                </a>
              )}
            </nav>
          )}
        </article>

        <aside class="doc-side doc-side--reading">
          {node.headings.length > 0 && (
            <div class="toc-card toc-card--desktop">
              <h3 class="toc-title">本页目录</h3>
              <ul class="toc-list">
                {node.headings
                  .filter((item) => item.level <= 2)
                  .map((heading) => (
                    <li>
                      <a href={`#${heading.id}`}>{heading.title}</a>
                    </li>
                  ))}
              </ul>
            </div>
          )}

          {node.book && node.siblingPages.length > 0 && (
            <div class="meta-card meta-card--book-rail">
              <h3>继续这本书</h3>
              <div class="doc-book-rail">
                {node.siblingPages.map((item) => (
                  <a
                    class:list={["slot-link", item.id === node.page.id && "slot-link--current"]}
                    href={item.url}
                    aria-current={item.id === node.page.id ? "page" : undefined}
                  >
                    <span class="slot-link-no">{item.slot}</span>
                    <strong>{item.title}</strong>
                  </a>
                ))}
              </div>
            </div>
          )}

          <div class="meta-card">
            <h3>所在位置</h3>
            <div class="mini-grid">
              {node.section && <a class="preview-item" href={node.section.url}>{node.section.title}</a>}
              {node.book && <a class="preview-item" href={node.book.url}>{node.book.title}</a>}
            </div>
          </div>
        </aside>
      </div>

      <div class="reader-notes-shell" data-reader-notes-shell>
        <button
          class="reader-notes-toggle"
          type="button"
          data-reader-notes-toggle
          aria-expanded="false"
          aria-label="打开段落笔记"
          title="段落笔记"
        ></button>

        <section class="meta-card reader-notes-panel" data-reader-notes-panel hidden>
          <div class="reader-notes-head reader-notes-head--panel">
            <div>
              <h3>段落笔记</h3>
            </div>
            <button class="tool-switch tool-switch--compact" type="button" data-reader-notes-close>收起</button>
          </div>
          <div class="reader-notes-toolbar">
            <button class="btn" type="button" data-reader-notes-capture>继续选段</button>
            <span class="meta-chip" data-reader-notes-count>0</span>
          </div>
          <p class="reader-notes-hint" data-reader-notes-hint>点铅笔后，直接点正文。</p>
          <p class="reader-notes-empty" data-reader-notes-empty>还没有笔记。</p>
          <div class="reader-notes-list" data-reader-notes-list></div>
        </section>

        <div class="reader-notes-editor" data-reader-notes-editor hidden>
          <div class="reader-notes-editor-card">
            <div class="reader-notes-head reader-notes-head--editor">
              <div>
                <h3 data-reader-notes-editor-title>记下这一段</h3>
                <p>保存在当前浏览器</p>
              </div>
            </div>
            <p class="reader-notes-quote" data-reader-notes-quote></p>
            <div class="reader-notes-field reader-notes-color-field">
              <span>颜色</span>
              <div class="reader-notes-colors" data-reader-notes-colors>
                <button class="reader-notes-color is-selected" type="button" data-reader-notes-color="amber" aria-label="黄色高亮"></button>
                <button class="reader-notes-color" type="button" data-reader-notes-color="teal" aria-label="青绿色高亮"></button>
                <button class="reader-notes-color" type="button" data-reader-notes-color="rose" aria-label="红色高亮"></button>
                <button class="reader-notes-color" type="button" data-reader-notes-color="violet" aria-label="紫色高亮"></button>
              </div>
            </div>
            <label class="reader-notes-field">
              <span>笔记（可不写）</span>
              <textarea data-reader-notes-input rows="5" placeholder="可以直接保存，只划线；也可以顺手写一句提醒。"></textarea>
            </label>
            <div class="reader-notes-editor-actions">
              <button class="btn btn-ghost" type="button" data-reader-notes-cancel>取消</button>
              <button class="btn" type="button" data-reader-notes-save>保存到本地</button>
            </div>
          </div>
        </div>

        <p class="reader-notes-status" data-reader-notes-status hidden></p>
      </div>

      {node.relatedBooks.length > 0 && (
        <section class="page-stack compact-stack compact-stack--reading reading-strip-group reading-strip-group--books">
          <div class="section-head section-head--reading-strip reading-strip-head">
            <div>
              <p class="eyebrow">换一本到同类书</p>
              <h2>同分类继续看</h2>
              <p class="reading-strip-copy">想暂时跳出这本，就从同一类里换一本角度不同的继续。</p>
            </div>
          </div>
          <div class="book-shelf book-shelf--reading-strip">
            {node.relatedBooks.map((item) => (
              <article class="book-card book-card--reading-strip reading-strip-card reading-strip-card--book">
                <a href={item.book.url}>
                  <div class="reading-strip-topline">
                    <p class="reading-strip-kicker">书</p>
                    <span class="section-index">{item.book.section_title}</span>
                  </div>
                  <h3>{item.book.title}</h3>
                  {item.book.summary && <p>{item.book.summary}</p>}
                  <div class="book-card-footer">
                    {item.shared_tags.length > 0
                      ? item.shared_tags.slice(0, 3).map((tag) => <span class="tag-pill">{tag}</span>)
                      : item.book.tags.slice(0, 3).map((tag) => <span class="tag-pill">{tag}</span>)}
                  </div>
                  <div class="section-enter">
                    <span>继续这类书</span>
                    <span>→</span>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </section>
      )}
    </div>
  )}
  <script>
    import { setupBookStatusControls } from "../../lib/book-status-storage";
    import { setupReaderParagraphNotes } from "../../lib/reader-paragraph-notes";

    const sectionSearchInput = document.getElementById("section-library-search");
    const sectionBookItems = Array.from(document.querySelectorAll("[data-section-book-item]"));
    const sectionEmpty = document.getElementById("section-library-empty");

    function updateSectionFilter() {
      const query =
        sectionSearchInput instanceof HTMLInputElement
          ? String(sectionSearchInput.value || "").toLowerCase().normalize("NFKC").trim()
          : "";

      let visibleCount = 0;

      sectionBookItems.forEach((item) => {
        if (!(item instanceof HTMLElement)) return;
        const searchText = String(item.dataset.searchText || "").toLowerCase().normalize("NFKC");
        const matched = !query || searchText.includes(query);
        item.hidden = !matched;
        if (matched) visibleCount += 1;
      });

      if (sectionEmpty instanceof HTMLElement) {
        sectionEmpty.hidden = visibleCount > 0;
      }
    }

    if (sectionSearchInput instanceof HTMLInputElement) {
      sectionSearchInput.addEventListener("input", updateSectionFilter);
    }

    setupBookStatusControls();

    if (document.querySelector("[data-reader-notes-root]")) {
      setupReaderParagraphNotes();
    }
  </script>
</BaseLayout>
