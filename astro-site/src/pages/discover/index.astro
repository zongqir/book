---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getDiscoverThemes, loadSiteIndex, type BookSummary } from "../../lib/content";

const themes = getDiscoverThemes();
const siteIndex = loadSiteIndex();

function getBookEntry(book: BookSummary) {
  const whyReadPage = siteIndex.pages.find((page) => page.book_id === book.id && String(page.slot ?? "").startsWith("00"));
  return {
    url: whyReadPage?.url ?? book.url,
    label: whyReadPage ? "打开导图" : "进入书页",
  };
}
---

<BaseLayout
  title="主题阅读"
  description="从一个问题开始，接上一条书和页面组成的阅读线。"
  canonicalPath="/discover/"
  ogDescription="从一个问题开始，接上一条书和页面组成的阅读线。"
  isDiscover={true}
>
  <div class="page-stack">
    <section class="library-panel library-panel--discover">
      <div class="library-hero library-hero--discover">
        <p class="hero-kicker">主题阅读</p>
        <h1>先挑一条线</h1>
        <p>不是先搜，也不是先看全部标签。先从你眼下最需要的那个问题开始。</p>
      </div>
    </section>

    <section class="theme-reading-grid" aria-label="主题入口">
      {themes.map((theme, index) => {
        const leadEntry = theme.leadBook ? getBookEntry(theme.leadBook) : null;
        return (
          <article class:list={["theme-reading-card", index === 0 && "theme-reading-card--featured"]}>
            <a href={`/discover/${theme.slug}/`}>
              <div class="theme-reading-card-top">
                <span class="meta-chip">主题 {String(index + 1).padStart(2, "0")}</span>
                <span class="theme-reading-card-count">{theme.counts.books} 本书</span>
              </div>
              <div class="theme-reading-card-copy">
                <h2>{theme.title}</h2>
                <p>{theme.summary}</p>
              </div>
              <div class="theme-reading-card-tags">
                {theme.tags.map((tag) => (
                  <span class="tag-pill">{tag}</span>
                ))}
              </div>
              {theme.leadBook && leadEntry && (
                <div class="theme-reading-card-start">
                  <span class="theme-reading-card-label">先从这本开始</span>
                  <strong>{theme.leadBook.title}</strong>
                  <span>{leadEntry.label}</span>
                </div>
              )}
              <div class="theme-reading-card-foot">
                <span>{theme.prompt}</span>
                <span>→</span>
              </div>
            </a>
          </article>
        );
      })}
    </section>
  </div>
</BaseLayout>
