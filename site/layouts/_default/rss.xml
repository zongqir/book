{{- $pages := slice -}}
{{- if .IsHome -}}
  {{- $pages = where site.RegularPages "Params.visibility" "ne" "internal" -}}
{{- else if .IsSection -}}
  {{- $pages = where .RegularPages "Params.visibility" "ne" "internal" -}}
{{- else -}}
  {{- $pages = where .Pages "Params.visibility" "ne" "internal" -}}
{{- end -}}
{{- $pages = first 50 ($pages.ByDate.Reverse) -}}
{{- $title := site.Title -}}
{{- if not .IsHome -}}
  {{- $title = printf "%s | %s" .Title site.Title -}}
{{- end -}}
{{- $description := site.Params.description -}}
{{- with .Description -}}
  {{- $description = . -}}
{{- end -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ $title }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ $description }}</description>
    <generator>Hugo</generator>
    <language>{{ site.LanguageCode }}</language>
    <atom:link href="{{ printf "%sindex.xml" .Permalink }}" rel="self" type="application/rss+xml" />
    {{- range $pages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ with .Params.summary }}{{ . | html }}{{ else }}{{ .Summary | html }}{{ end }}</description>
    </item>
    {{- end }}
  </channel>
</rss>
