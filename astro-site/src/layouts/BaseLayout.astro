---
type Props = {
  title?: string;
  description?: string;
  isHome?: boolean;
  isLibrary?: boolean;
};

const {
  title = "读书库",
  description = "个人读书与研究资料库",
  isHome = false,
  isLibrary = false,
} = Astro.props;
const pageTitle = isHome ? "读书库" : `${title} | 读书库`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#2f5b7c" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="alternate" type="application/json" title="读书库 内容索引" href="/data/site-content.json" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Noto+Sans+SC:wght@400;500;700&family=Noto+Serif+SC:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body class:list={[isLibrary && "is-library"]}>
    <div class="page-frame">
      <header class="site-header-wrap">
        <div class="site-header shell">
          <div class="identity">
            <a class="brand" href="/">
              <span>读书库</span>
            </a>
            <span class="tagline">个人读书与研究资料库</span>
          </div>
          <nav class="top-nav" aria-label="主导航">
            <a class:list={["nav-pill", isHome && "is-active"]} href="/">首页</a>
            {isHome && (
              <>
                <a class="nav-pill nav-pill--subtle" href="#home-tools">随机入口</a>
                <a class="nav-pill nav-pill--subtle" href="#home-categories">分类导航</a>
              </>
            )}
            <a class:list={["nav-pill", isLibrary && "is-active"]} href="/library/">目录</a>
          </nav>
        </div>
      </header>
    </div>
    <main class="container shell">
      <slot />
    </main>
    <footer class="site-footer shell">
      <p>Book Lab 用来沉淀阅读判断、专题研究和结构化笔记。</p>
      <p class="site-footer-meta">{new Date().getFullYear()} · 个人读书与研究资料库</p>
    </footer>
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", function () {
          navigator.serviceWorker.register("/sw.js");
        });
      }
    </script>
  </body>
</html>
