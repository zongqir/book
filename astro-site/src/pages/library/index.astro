---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLibraryIndex } from "../../lib/content";

const sections = getLibraryIndex();
const books = sections.flatMap((section) =>
  section.books.map((book) => ({
    ...book,
    section_title: section.title,
  })),
);
---

<BaseLayout title="目录" description="从分类进入书页和文稿，直接往里读。" canonicalPath="/library/" ogDescription="从分类进入书页和文稿，直接往里读。" isLibrary={true}>
  <div class="page-stack">
    <section class="library-panel library-panel--index">
      <div class="library-hero">
        <h1>全部分类</h1>
        <label class="field-control library-index-search">
          <input id="library-index-search" type="search" placeholder="搜书名" aria-label="搜索书名" />
        </label>
      </div>
    </section>

    <section class="library-search-results" id="library-search-results" hidden>
      {books.map((book) => (
        <a
          class="library-search-card"
          href={book.url}
          data-library-book-item
          data-search-text={book.title}
        >
          <span class="meta-chip">{book.section_title}</span>
          <strong>{book.title}</strong>
        </a>
      ))}
    </section>

    <section class="library-sections" id="library-index-list">
      {sections.map((section) => (
        <article
          class="library-index-card"
          data-library-index-item
        >
          <a href={section.url}>
            <h3>{section.title}</h3>
            <p class="section-volume">
              <strong>{section.book_count}</strong>
              <span>本书</span>
            </p>
            <div class="library-index-preview">
              {section.books.slice(0, 3).map((book) => (
                <span class="preview-item">{book.title}</span>
              ))}
            </div>
            <div class="section-enter">
              <span>打开分类</span>
              <span>→</span>
            </div>
          </a>
        </article>
      ))}
    </section>
    <p class="preview-item preview-item--muted library-index-empty" id="library-index-empty" hidden>没搜到匹配项，换个书名试试。</p>
  </div>

  <script>
    const searchInput = document.getElementById("library-index-search");
    const sectionList = document.getElementById("library-index-list");
    const searchResults = document.getElementById("library-search-results");
    const bookItems = Array.from(document.querySelectorAll("[data-library-book-item]"));
    const empty = document.getElementById("library-index-empty");

    function matchesSearch(searchText, query) {
      const source = String(searchText || "").toLowerCase().normalize("NFKC");
      const normalizedQuery = String(query || "").toLowerCase().normalize("NFKC").trim();
      if (!normalizedQuery) return true;
      return source.includes(normalizedQuery);
    }

    function updateLibraryIndexFilter() {
      const query =
        searchInput instanceof HTMLInputElement
          ? searchInput.value.trim().toLowerCase().normalize("NFKC")
          : "";

      if (!query) {
        bookItems.forEach((item) => {
          if (item instanceof HTMLElement) item.hidden = false;
        });
        if (sectionList instanceof HTMLElement) sectionList.hidden = false;
        if (searchResults instanceof HTMLElement) searchResults.hidden = true;
        if (empty instanceof HTMLElement) empty.hidden = true;
        return;
      }

      let visibleCount = 0;

      bookItems.forEach((item) => {
        if (!(item instanceof HTMLElement)) return;
        const searchText = String(item.dataset.searchText || "");
        const matched = matchesSearch(searchText, query);
        item.hidden = !matched;
        if (matched) visibleCount += 1;
      });

      if (sectionList instanceof HTMLElement) sectionList.hidden = true;
      if (searchResults instanceof HTMLElement) searchResults.hidden = visibleCount === 0;
      if (empty instanceof HTMLElement) {
        empty.hidden = visibleCount > 0;
      }
    }

    if (searchInput instanceof HTMLInputElement) {
      searchInput.addEventListener("input", updateLibraryIndexFilter);
    }
  </script>
</BaseLayout>
