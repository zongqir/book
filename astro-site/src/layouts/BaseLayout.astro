---
import "@recogito/text-annotator/dist/text-annotator.css";
import "../styles/astro-theme.css";

type Props = {
  title?: string;
  description?: string;
  isHome?: boolean;
  isLibrary?: boolean;
  isDiscover?: boolean;
};

const {
  title = "读书库",
  description = "读书库",
  isHome = false,
  isLibrary = false,
  isDiscover = false,
} = Astro.props;
const pageTitle = isHome ? "读书库" : `${title} | 读书库`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#2f5b7c" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="alternate" type="application/json" title="读书库 内容索引" href="/data/site-content.json" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Noto+Sans+SC:wght@400;500;700&family=Noto+Serif+SC:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class:list={["theme-astro", isLibrary && "is-library", isHome && "is-home", isDiscover && "is-discover"]}>
    <div class="page-frame">
      <header class="site-header-wrap">
        <div class="site-header shell">
          <div class="identity">
            <a class="brand" href="/">
              <span class="brand-mark" aria-hidden="true">BQ</span>
              <span>读书库</span>
            </a>
          </div>
          <nav class="top-nav" aria-label="主导航">
            <a class:list={["nav-pill", isHome && "is-active"]} href="/">首页</a>
            <a class:list={["nav-pill", isDiscover && "is-active"]} href="/discover/">发现</a>
            <a class:list={["nav-pill", isLibrary && "is-active"]} href="/library/">目录</a>
            {isHome && (
              <>
                <a class="nav-pill nav-pill--subtle" href="#home-tools">随机翻书</a>
                <a class="nav-pill nav-pill--subtle" href="#home-categories">分类</a>
              </>
            )}
          </nav>
        </div>
      </header>
    </div>
    <main class="site-main shell">
      <slot />
    </main>
    <footer class="site-footer shell">
      <div class="site-footer-inner">
        <p class="site-footer-meta">book.zongqir.com · {new Date().getFullYear()}</p>
      </div>
    </footer>
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", function () {
          navigator.serviceWorker.register("/sw.js");
        });
      }
    </script>
  </body>
</html>
