---
import "../styles/astro-theme.css";
import { getAndroidAppDownloadConfig } from "../lib/app-distribution";
import { toInternalHref } from "../lib/internal-links";

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: "website" | "article";
  ogImage?: string;
  ogImageAlt?: string;
  isHome?: boolean;
  isLibrary?: boolean;
};

const {
  title = "读书库",
  description = "读书库",
  canonicalPath,
  ogTitle,
  ogDescription,
  ogType = "website",
  ogImage = "/icons/icon-512.png",
  ogImageAlt,
  isHome = false,
  isLibrary = false,
} = Astro.props;
const pageTitle = isHome ? "读书库" : `${title} | 读书库`;
const pathname = Astro.url.pathname;
const canonicalUrl = new URL(canonicalPath || pathname, Astro.site);
const socialTitle = ogTitle || pageTitle;
const socialDescription = ogDescription || description;
const socialImage = new URL(ogImage, Astro.site);
const socialImageAlt = ogImageAlt || socialTitle;
const isNotes = pathname.startsWith("/notes");
const isAppDownload = pathname.startsWith("/app");
const mobileSectionLabel = isHome ? "首页" : isLibrary ? "目录" : isNotes ? "笔记" : title;
const appDownload = getAndroidAppDownloadConfig();
const showAppDownloadEntry = appDownload.available;
const homeHref = toInternalHref("/");
const libraryHref = toInternalHref("/library/");
const notesHref = toInternalHref("/notes/");
const appHref = toInternalHref("/app/");
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <script is:inline>
      (function () {
        function looksLikeNativeApp() {
          var hostname = window.location.hostname || "";
          var protocol = window.location.protocol || "";
          if (hostname === "localhost") return true;
          if (protocol === "capacitor:" || protocol === "file:") return true;
          return false;
        }

        function applyNativeAppClass() {
          var root = document.documentElement;
          var ua = window.navigator.userAgent || "";
          var capacitor = window.Capacitor;
          var isNativeApp = Boolean(
            capacitor && typeof capacitor.isNativePlatform === "function" && capacitor.isNativePlatform(),
          );

          if (!isNativeApp && looksLikeNativeApp()) {
            isNativeApp = true;
          }

          if (!isNativeApp) return;
          root.classList.add("is-capacitor-app");
          if (/Android/i.test(ua)) {
            root.classList.add("is-capacitor-android");
          }
        }

        applyNativeAppClass();
        window.addEventListener("load", applyNativeAppClass, { once: true });
        document.addEventListener("DOMContentLoaded", applyNativeAppClass, { once: true });
      })();
    </script>
    {isLibrary && (
      <script>
        import { initShareActions } from "../lib/share-actions";

        initShareActions();
      </script>
    )}
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="读书库 RSS" href="/rss.xml" />
    <meta property="og:site_name" content="读书库" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:type" content={ogImage.endsWith(".svg") ? "image/svg+xml" : "image/png"} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={socialDescription} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    <meta name="application-name" content="读书库" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="读书库" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="theme-color" content="#2f5b7c" />
    <meta name="color-scheme" content="light" />
    <meta name="msapplication-TileColor" content="#2f5b7c" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="192x192" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="alternate" type="application/json" title="读书库 内容索引" href="/data/site-content.json" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Noto+Sans+SC:wght@400;500;700&family=Noto+Serif+SC:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class:list={["theme-astro", isLibrary && "is-library", isHome && "is-home", isNotes && "is-notes"]}>
    <div class="page-frame">
      <header class="site-header-wrap">
        <div class="site-header shell">
          <div class="identity">
            <a class="brand" href={homeHref}>
              <span class="brand-mark" aria-hidden="true">BQ</span>
              <span>读书库</span>
            </a>
            <span class="mobile-page-badge">{mobileSectionLabel}</span>
          </div>
          <div class="site-header-actions">
            <nav class="top-nav" aria-label="主导航">
              <a class:list={["nav-pill", isHome && "is-active"]} href={homeHref}>首页</a>
              <a class:list={["nav-pill", isLibrary && "is-active"]} href={libraryHref}>目录</a>
              <a class:list={["nav-pill", isNotes && "is-active"]} href={notesHref}>笔记</a>
            </nav>
            <button
              class="site-settings-toggle"
              type="button"
              data-settings-toggle
              aria-haspopup="dialog"
              aria-expanded="false"
              aria-controls="site-settings-sheet"
              aria-label="打开设置与数据"
            >
              <svg viewBox="0 0 20 20" aria-hidden="true">
                <circle cx="10" cy="10" r="2.1"></circle>
                <path d="M10 3.35v1.7"></path>
                <path d="M10 14.95v1.7"></path>
                <path d="m5.3 5.3 1.2 1.2"></path>
                <path d="m13.5 13.5 1.2 1.2"></path>
                <path d="M3.35 10h1.7"></path>
                <path d="M14.95 10h1.7"></path>
                <path d="m5.3 14.7 1.2-1.2"></path>
                <path d="m13.5 6.5 1.2-1.2"></path>
              </svg>
            </button>
          </div>
        </div>
      </header>
    </div>
    <main class="site-main shell">
      <slot />
    </main>
    {(!isHome || showAppDownloadEntry) && (
      <footer class="site-footer shell">
        <div class:list={["site-footer-inner", showAppDownloadEntry && "site-footer-inner--with-links"]}>
          <p class="site-footer-meta">book.zongqir.com · {new Date().getFullYear()}</p>
          {showAppDownloadEntry && (
            <div class="site-footer-links">
              <a class:list={["site-footer-link", isAppDownload && "is-active"]} href={appHref}>
                Android App
              </a>
            </div>
          )}
        </div>
      </footer>
    )}

    <nav class="mobile-app-dock" aria-label="移动导航">
      <a class:list={["mobile-dock-item", isHome && "is-active"]} href={homeHref}>
        <span class="mobile-dock-dot" aria-hidden="true"></span>
        <span>首页</span>
      </a>
      <a class:list={["mobile-dock-item", isLibrary && "is-active"]} href={libraryHref}>
        <span class="mobile-dock-dot" aria-hidden="true"></span>
        <span>目录</span>
      </a>
      <a class:list={["mobile-dock-item", isNotes && "is-active"]} href={notesHref}>
        <span class="mobile-dock-dot" aria-hidden="true"></span>
        <span>笔记</span>
      </a>
      <button
        class="mobile-dock-item mobile-dock-action"
        type="button"
        data-settings-toggle
        aria-haspopup="dialog"
        aria-expanded="false"
        aria-controls="site-settings-sheet"
        aria-label="打开设置与数据"
      >
        <span class="mobile-dock-dot mobile-dock-dot--settings" aria-hidden="true"></span>
        <span>设置</span>
      </button>
    </nav>

    <div class="network-toast" id="network-toast" hidden>当前离线，优先使用已缓存页面。</div>

    <section class="pwa-prompt" id="pwa-prompt" hidden aria-live="polite">
      <div class="pwa-prompt-copy">
        <p class="eyebrow">主屏入口</p>
        <h2 class="pwa-prompt-title" id="pwa-prompt-title">把读书库装到主屏幕</h2>
        <p class="pwa-prompt-text" id="pwa-prompt-text">安装后可以像应用一样打开，也能继续看已缓存的页面和笔记。</p>
      </div>
      <div class="pwa-prompt-actions">
        <button class="btn" id="pwa-install-button" type="button">立即安装</button>
        <button class="tool-switch" id="pwa-dismiss-button" type="button">稍后</button>
      </div>
    </section>

    <section class="site-settings-sheet" id="site-settings-sheet" hidden aria-hidden="true">
      <div class="site-settings-sheet-backdrop" data-settings-close></div>
      <div class="site-settings-panel" role="dialog" aria-modal="true" aria-labelledby="site-settings-title">
        <div class="site-settings-head">
          <div>
            <p class="eyebrow">设置与数据</p>
            <h2 id="site-settings-title">本地笔记</h2>
          </div>
          <button class="tool-switch tool-switch--compact" type="button" data-settings-close>收起</button>
        </div>
        <div class="site-settings-summary">
          <p class="site-settings-note-count" id="site-settings-note-count">正在整理本地笔记…</p>
          <p class="site-settings-status" id="site-settings-status">导入前先导出一次。</p>
        </div>
        <div class="site-settings-actions">
          <button class="btn btn-ghost" id="site-settings-export" type="button">导出笔记</button>
          <button class="btn btn-ghost" id="site-settings-import-trigger" type="button">导入笔记</button>
          <button class="btn btn-ghost btn-ghost--danger" id="site-settings-clear" type="button">清空本地</button>
          <input id="site-settings-import-input" type="file" accept="application/json,.json" hidden />
        </div>
        <div class="site-settings-links">
          <a class="tool-switch" href={toInternalHref("/offline/")}>离线说明</a>
          {showAppDownloadEntry && appDownload.latestApkUrl && (
            <a class="tool-switch" href={appDownload.latestApkUrl} target="_blank" rel="noreferrer">Android 下载</a>
          )}
          {showAppDownloadEntry && !appDownload.latestApkUrl && appDownload.releasePageUrl && (
            <a class="tool-switch" href={appDownload.releasePageUrl} target="_blank" rel="noreferrer">查看发布页</a>
          )}
        </div>
      </div>
    </section>

    <script is:inline>
      (function () {
        var PWA_DISMISS_KEY = "book:pwa-install-dismissed-until:v1";
        var LAST_VISIT_KEY = "book:last-visit:v1";
        var PWA_DISMISS_MS = 1000 * 60 * 60 * 24 * 5;
        var promptNode = document.getElementById("pwa-prompt");
        var promptTitle = document.getElementById("pwa-prompt-title");
        var promptText = document.getElementById("pwa-prompt-text");
        var installButton = document.getElementById("pwa-install-button");
        var dismissButton = document.getElementById("pwa-dismiss-button");
        var networkToast = document.getElementById("network-toast");
        var deferredInstallPrompt = null;
        var networkTimer = 0;
        var wasOffline = !navigator.onLine;

        function readDismissedUntil() {
          try {
            return Number(window.localStorage.getItem(PWA_DISMISS_KEY) || "0");
          } catch (error) {
            return 0;
          }
        }

        function writeDismissedUntil(value) {
          try {
            if (value) {
              window.localStorage.setItem(PWA_DISMISS_KEY, String(value));
            } else {
              window.localStorage.removeItem(PWA_DISMISS_KEY);
            }
          } catch (error) {
            console.warn("Failed to persist PWA prompt state", error);
          }
        }

        function isStandalone() {
          return window.matchMedia("(display-mode: standalone)").matches || window.navigator.standalone === true;
        }

        function isIosSafari() {
          var ua = window.navigator.userAgent || "";
          var isIosDevice = /iPad|iPhone|iPod/.test(ua) || (ua.includes("Mac") && "ontouchend" in document);
          var isWebkit = /WebKit/i.test(ua);
          var isOtherBrowser = /CriOS|FxiOS|EdgiOS|OPiOS|DuckDuckGo/i.test(ua);
          return isIosDevice && isWebkit && !isOtherBrowser;
        }

        function canShowPrompt() {
          return !isStandalone() && Date.now() > readDismissedUntil();
        }

        function setPromptContent(mode) {
          if (!(promptNode instanceof HTMLElement)) return;
          promptNode.dataset.mode = mode;

          if (mode === "ios") {
            if (promptTitle instanceof HTMLElement) {
              promptTitle.textContent = "把读书库加到主屏幕";
            }
            if (promptText instanceof HTMLElement) {
              promptText.textContent = "在 Safari 点分享，再选“添加到主屏幕”。装好后会像应用一样打开。";
            }
            if (installButton instanceof HTMLButtonElement) {
              installButton.hidden = true;
            }
            if (dismissButton instanceof HTMLButtonElement) {
              dismissButton.textContent = "知道了";
            }
            return;
          }

          if (promptTitle instanceof HTMLElement) {
            promptTitle.textContent = "把读书库装到主屏幕";
          }
          if (promptText instanceof HTMLElement) {
            promptText.textContent = "安装后可以像应用一样打开，也能继续看已缓存的页面和笔记。";
          }
          if (installButton instanceof HTMLButtonElement) {
            installButton.hidden = false;
            installButton.textContent = "立即安装";
          }
          if (dismissButton instanceof HTMLButtonElement) {
            dismissButton.textContent = "稍后";
          }
        }

        function showPrompt(mode) {
          if (!(promptNode instanceof HTMLElement) || !canShowPrompt()) return;
          setPromptContent(mode);
          promptNode.hidden = false;
          document.body.classList.add("has-pwa-prompt");
        }

        function hidePrompt(shouldPersist) {
          if (!(promptNode instanceof HTMLElement)) return;
          promptNode.hidden = true;
          document.body.classList.remove("has-pwa-prompt");
          if (shouldPersist) {
            writeDismissedUntil(Date.now() + PWA_DISMISS_MS);
          }
        }

        function showNetworkToast(message, sticky) {
          if (!(networkToast instanceof HTMLElement)) return;
          if (networkTimer) {
            window.clearTimeout(networkTimer);
            networkTimer = 0;
          }
          networkToast.textContent = message;
          networkToast.hidden = false;
          if (!sticky) {
            networkTimer = window.setTimeout(function () {
              networkToast.hidden = true;
            }, 2600);
          }
        }

        function syncNetworkToast() {
          if (!navigator.onLine) {
            showNetworkToast("当前离线，优先使用已缓存页面。", true);
          } else if (wasOffline) {
            showNetworkToast("网络已恢复，缓存会自动刷新。", false);
          } else if (networkToast instanceof HTMLElement) {
            networkToast.hidden = true;
          }
          wasOffline = !navigator.onLine;
        }

        window.addEventListener("offline", syncNetworkToast);
        window.addEventListener("online", syncNetworkToast);
        syncNetworkToast();

        function rememberLibraryVisit() {
          if (!window.location.pathname.startsWith("/library/") || window.location.pathname === "/library/") return;
          var titleNode = document.querySelector("h1");
          if (!(titleNode instanceof HTMLElement)) return;

          var breadcrumbParts = Array.prototype.slice
            .call(document.querySelectorAll(".breadcrumb a, .breadcrumb span"))
            .map(function (node) {
              return node && node.textContent ? node.textContent.trim() : "";
            })
            .filter(function (text) {
              return text && text !== "/";
            });
          var summaryNode = document.querySelector(".doc-summary, .page-intro p");
          var summary = summaryNode && summaryNode.textContent
            ? summaryNode.textContent.replace(/\s+/g, " ").trim().slice(0, 96)
            : "";
          var payload = {
            url: window.location.pathname + window.location.search + window.location.hash,
            title: titleNode.textContent.trim(),
            label: document.querySelector(".doc-content[data-page-id]")
              ? "继续这页"
              : document.querySelector(".slot-rail")
                ? "回到这本书"
                : "回到这一类",
            context: breadcrumbParts.slice(1).join(" / "),
            summary: summary,
            updatedAt: new Date().toISOString(),
          };

          try {
            window.localStorage.setItem(LAST_VISIT_KEY, JSON.stringify(payload));
          } catch (error) {
            console.warn("Failed to persist last visit", error);
          }
        }

        rememberLibraryVisit();

        window.addEventListener("beforeinstallprompt", function (event) {
          event.preventDefault();
          deferredInstallPrompt = event;
          showPrompt("native");
        });

        window.addEventListener("appinstalled", function () {
          deferredInstallPrompt = null;
          writeDismissedUntil(0);
          hidePrompt(false);
          showNetworkToast("已安装到主屏幕。", false);
        });

        if (installButton instanceof HTMLButtonElement) {
          installButton.addEventListener("click", async function () {
            if (!deferredInstallPrompt) return;
            deferredInstallPrompt.prompt();
            const choice = await deferredInstallPrompt.userChoice;
            deferredInstallPrompt = null;
            if (choice && choice.outcome === "accepted") {
              writeDismissedUntil(0);
              hidePrompt(false);
              return;
            }
            hidePrompt(true);
          });
        }

        if (dismissButton instanceof HTMLButtonElement) {
          dismissButton.addEventListener("click", function () {
            hidePrompt(true);
          });
        }

        if ("serviceWorker" in navigator) {
          window.addEventListener("load", async function () {
            try {
              const registration = await navigator.serviceWorker.register("/sw.js", { scope: "/" });
              if (registration.waiting) {
                registration.waiting.postMessage("SKIP_WAITING");
              }
              registration.addEventListener("updatefound", function () {
                const installing = registration.installing;
                if (!installing) return;
                installing.addEventListener("statechange", function () {
                  if (installing.state === "installed" && registration.waiting) {
                    registration.waiting.postMessage("SKIP_WAITING");
                  }
                });
              });
              let refreshing = false;
              navigator.serviceWorker.addEventListener("controllerchange", function () {
                if (refreshing) return;
                refreshing = true;
                window.location.reload();
              });
            } catch (error) {
              console.error("Service worker registration failed", error);
            }

            if (!deferredInstallPrompt && isIosSafari()) {
              window.setTimeout(function () {
                showPrompt("ios");
              }, 900);
            }
          });
        }
      })();
    </script>
    <script>
      import {
        clearReaderNotebook,
        exportReaderNotebook,
        importReaderNotebook,
        listAllReaderNotes,
      } from "../lib/reader-storage";

      const settingsSheet = document.getElementById("site-settings-sheet");
      const settingsToggles = Array.from(document.querySelectorAll("[data-settings-toggle]"));
      const settingsCount = document.getElementById("site-settings-note-count");
      const settingsStatus = document.getElementById("site-settings-status");
      const settingsExport = document.getElementById("site-settings-export");
      const settingsImportTrigger = document.getElementById("site-settings-import-trigger");
      const settingsImportInput = document.getElementById("site-settings-import-input");
      const settingsClear = document.getElementById("site-settings-clear");
      const settingsCloseNodes = Array.from(document.querySelectorAll("[data-settings-close]"));

      function setSettingsBusy(next) {
        [...settingsToggles, settingsExport, settingsImportTrigger, settingsClear].forEach((node) => {
          if (node instanceof HTMLButtonElement) {
            node.disabled = next;
          }
        });
      }

      function setSettingsStatus(message, tone) {
        if (!(settingsStatus instanceof HTMLElement)) return;
        settingsStatus.textContent = message;
        settingsStatus.dataset.tone = tone || "neutral";
      }

      function downloadSettingsExport(payload) {
        const filenameDate = new Date().toISOString().slice(0, 10);
        const blob = new Blob([JSON.stringify(payload, null, 2)], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        const anchor = document.createElement("a");
        anchor.href = url;
        anchor.download = "reader-notes-" + filenameDate + ".json";
        document.body.appendChild(anchor);
        anchor.click();
        anchor.remove();
        URL.revokeObjectURL(url);
      }

      async function refreshSettingsSummary() {
        if (!(settingsCount instanceof HTMLElement)) return;
        try {
          const notes = await listAllReaderNotes();
          settingsCount.textContent = notes.length ? "当前有 " + notes.length + " 条本地笔记。" : "当前还没有本地笔记。";
        } catch (error) {
          console.error("Failed to read settings notes summary", error);
          settingsCount.textContent = "本地笔记暂时读不到。";
          setSettingsStatus("读取失败了，稍后再试。", "danger");
        }
      }

      function openSettingsSheet() {
        if (!(settingsSheet instanceof HTMLElement)) return;
        settingsSheet.hidden = false;
        settingsSheet.setAttribute("aria-hidden", "false");
        document.body.classList.add("site-settings-open");
        settingsToggles.forEach((node) => node.setAttribute("aria-expanded", "true"));
        void refreshSettingsSummary();
      }

      function closeSettingsSheet() {
        if (!(settingsSheet instanceof HTMLElement)) return;
        settingsSheet.hidden = true;
        settingsSheet.setAttribute("aria-hidden", "true");
        document.body.classList.remove("site-settings-open");
        settingsToggles.forEach((node) => node.setAttribute("aria-expanded", "false"));
      }

      async function readImportFile(file) {
        const text = await file.text();
        return JSON.parse(text);
      }

      settingsToggles.forEach((node) => {
        if (!(node instanceof HTMLButtonElement)) return;
        node.addEventListener("click", () => {
          if (settingsSheet instanceof HTMLElement && !settingsSheet.hidden) {
            closeSettingsSheet();
            return;
          }
          openSettingsSheet();
        });
      });

      settingsCloseNodes.forEach((node) => {
        if (!(node instanceof HTMLElement)) return;
        node.addEventListener("click", () => {
          closeSettingsSheet();
        });
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeSettingsSheet();
        }
      });

      if (settingsExport instanceof HTMLButtonElement) {
        settingsExport.addEventListener("click", async () => {
          setSettingsBusy(true);
          try {
            const payload = await exportReaderNotebook();
            downloadSettingsExport(payload);
            setSettingsStatus("导出完成。", "success");
          } catch (error) {
            console.error("Failed to export reader notes from settings", error);
            setSettingsStatus("导出失败了。", "danger");
          } finally {
            setSettingsBusy(false);
            void refreshSettingsSummary();
          }
        });
      }

      if (settingsImportTrigger instanceof HTMLButtonElement && settingsImportInput instanceof HTMLInputElement) {
        settingsImportTrigger.addEventListener("click", () => {
          settingsImportInput.click();
        });

        settingsImportInput.addEventListener("change", async () => {
          const file = settingsImportInput.files && settingsImportInput.files[0];
          if (!file) return;
          setSettingsBusy(true);
          try {
            const payload = await readImportFile(file);
            await importReaderNotebook(payload);
            setSettingsStatus("导入完成。", "success");
          } catch (error) {
            console.error("Failed to import reader notes from settings", error);
            setSettingsStatus(error instanceof Error ? error.message : "导入失败了。", "danger");
          } finally {
            settingsImportInput.value = "";
            setSettingsBusy(false);
            void refreshSettingsSummary();
          }
        });
      }

      if (settingsClear instanceof HTMLButtonElement) {
        settingsClear.addEventListener("click", async () => {
          if (!window.confirm("要清空这个设备里的全部本地笔记吗？")) return;
          setSettingsBusy(true);
          try {
            await clearReaderNotebook();
            setSettingsStatus("本地笔记已经清空。", "success");
          } catch (error) {
            console.error("Failed to clear reader notes from settings", error);
            setSettingsStatus("清空失败了。", "danger");
          } finally {
            setSettingsBusy(false);
            void refreshSettingsSummary();
          }
        });
      }
    </script>
  </body>
</html>
