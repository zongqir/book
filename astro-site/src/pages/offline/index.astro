---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="离线状态" description="当前网络不可用，你仍然可以继续查看已缓存的目录和页面。">
  <section class="library-panel">
    <div class="library-hero">
      <h1>现在离线了</h1>
      <p>网络暂时不可用。你还可以回到首页、目录，或继续看已经缓存过的页面。</p>
      <div class="actions library-hero-actions">
        <a class="btn" href="/">回首页</a>
        <a class="btn btn-ghost" href="/library/">去目录</a>
      </div>
    </div>
  </section>
</BaseLayout>
