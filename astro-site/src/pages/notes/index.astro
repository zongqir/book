---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="个人" description="回看你留在这个浏览器里的笔记、收藏的书和收藏的文章。">
  <div class="page-stack notes-dashboard">
    <section class="library-panel notes-stage">
      <div class="notes-hero">
        <div>
          <p class="hero-kicker">个人</p>
          <h1>个人</h1>
        </div>
        <p>这里放你留在这个浏览器里的笔记、收藏的书，以及反复想回来的文章。</p>
        <div class="stats-strip notes-stage-strip">
          <div class="stat-block">
            <span class="stat-label">本地笔记</span>
            <strong class="stat-value" id="notes-total-count">0</strong>
          </div>
          <div class="stat-block">
            <span class="stat-label">收藏书籍</span>
            <strong class="stat-value" id="favorite-books-count">0</strong>
          </div>
          <div class="stat-block">
            <span class="stat-label">收藏文章</span>
            <strong class="stat-value" id="favorite-pages-count">0</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="content-card notes-results-card personal-collections-card">
      <div class="section-head personal-collections-head">
        <div>
          <p class="eyebrow">收藏</p>
          <h2>你想反复回来的内容</h2>
        </div>
      </div>

      <div class="personal-collections-grid">
        <section class="personal-collection">
          <div class="personal-collection-head">
            <div>
              <p class="eyebrow">书</p>
              <h3>收藏的书</h3>
            </div>
            <span class="meta-chip" id="favorite-books-inline-count">0 本</span>
          </div>
          <div class="personal-collection-list" id="favorite-books-results"></div>
          <div class="notes-empty personal-empty" id="favorite-books-empty" hidden>
            <h2>还没有收藏的书</h2>
            <p>在书页点一下爱心，就会留在这里。</p>
          </div>
        </section>

        <section class="personal-collection">
          <div class="personal-collection-head">
            <div>
              <p class="eyebrow">文章</p>
              <h3>收藏的文章</h3>
            </div>
            <span class="meta-chip" id="favorite-pages-inline-count">0 篇</span>
          </div>
          <div class="personal-collection-list" id="favorite-pages-results"></div>
          <div class="notes-empty personal-empty" id="favorite-pages-empty" hidden>
            <h2>还没有收藏的文章</h2>
            <p>在任意章节页点一下爱心，就会留在这里。</p>
          </div>
        </section>
      </div>
    </section>

    <section class="content-card notes-toolbar-card">
      <details class="notes-filters" open>
        <summary class="notes-filters-summary">
          <span>搜索与筛选</span>
          <span class="notes-filters-state" data-notes-filters-state>正在整理…</span>
        </summary>

        <div class="notes-filters-body">
          <div class="notes-toolbar-row">
            <label class="field-control field-control--wide notes-toolbar-search">
              <span>搜索</span>
              <input id="notes-search" type="search" placeholder="搜书名、文稿标题、摘句或你写下的提醒" />
            </label>

            <button class="notes-icon-button notes-icon-button--sort" id="notes-sort-toggle" type="button" aria-label="当前按最近更新排序" title="当前按最近更新排序">
              <svg class="notes-icon-svg" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M7 4v12"></path>
                <path d="M4.5 13.5 7 16l2.5-2.5"></path>
                <path d="M12 6h4"></path>
                <path d="M12 10h3"></path>
                <path d="M12 14h2"></path>
              </svg>
              <span class="notes-sort-label" data-notes-sort-label>最近</span>
            </button>
          </div>

          <div class="notes-filter-row">
            <div class="notes-filter-group notes-filter-group--colors" aria-label="颜色筛选">
              <button class="notes-filter-reset is-active" type="button" data-notes-color="all" aria-label="全部颜色" title="全部颜色">
                <svg class="notes-icon-svg" viewBox="0 0 20 20" aria-hidden="true">
                  <circle cx="10" cy="10" r="6.25"></circle>
                  <path d="M10 6.5v7"></path>
                  <path d="M6.5 10h7"></path>
                </svg>
              </button>
              <button class="notes-filter-dot notes-filter-dot--amber" type="button" data-notes-color="amber" aria-label="筛选黄色高亮"></button>
              <button class="notes-filter-dot notes-filter-dot--teal" type="button" data-notes-color="teal" aria-label="筛选青绿高亮"></button>
              <button class="notes-filter-dot notes-filter-dot--rose" type="button" data-notes-color="rose" aria-label="筛选红色高亮"></button>
              <button class="notes-filter-dot notes-filter-dot--violet" type="button" data-notes-color="violet" aria-label="筛选紫色高亮"></button>
            </div>

            <div class="notes-stage-actions" aria-label="笔记工具">
              <button class="notes-icon-button" id="notes-import-trigger" type="button" aria-label="导入 JSON" title="导入 JSON">
                <svg class="notes-icon-svg" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M10 2.75v8.5"></path>
                  <path d="m6.75 8.25 3.25 3.25 3.25-3.25"></path>
                  <path d="M4.5 12.75v2a1.75 1.75 0 0 0 1.75 1.75h7.5a1.75 1.75 0 0 0 1.75-1.75v-2"></path>
                </svg>
              </button>
              <button class="notes-icon-button" id="notes-export" type="button" aria-label="导出 JSON" title="导出 JSON">
                <svg class="notes-icon-svg" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M10 17.25v-8.5"></path>
                  <path d="m6.75 11.75 3.25-3.25 3.25 3.25"></path>
                  <path d="M4.5 7.25v-2A1.75 1.75 0 0 1 6.25 3.5h7.5a1.75 1.75 0 0 1 1.75 1.75v2"></path>
                </svg>
              </button>
              <button class="notes-icon-button notes-icon-button--danger" id="notes-clear" type="button" aria-label="清空本地" title="清空本地">
                <svg class="notes-icon-svg" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M7 4.75h6"></path>
                  <path d="M4.5 5.75h11"></path>
                  <path d="M6.25 5.75v8.25A1.5 1.5 0 0 0 7.75 15.5h4.5a1.5 1.5 0 0 0 1.5-1.5V5.75"></path>
                  <path d="M8.5 8.5v4"></path>
                  <path d="M11.5 8.5v4"></path>
                </svg>
              </button>
              <input id="notes-import-input" type="file" accept="application/json,.json" hidden />
            </div>
          </div>

          <div class="notes-meta-line">
            <p class="notes-summary" id="notes-summary">正在整理…</p>
            <p class="notes-status" id="notes-status">仅本地保存，导入前先导出。</p>
          </div>
        </div>
      </details>
    </section>

    <section class="content-card notes-results-card">
      <div class="notes-empty" id="notes-empty" hidden>
        <h2 id="notes-empty-title">还没有本地笔记</h2>
        <p>去任意一篇正文里划一段，或者导入你之前备份过的笔记。</p>
      </div>
      <div class="notes-results" id="notes-results" aria-live="polite"></div>
    </section>
  </div>

  <script>
    import { getBookStatusStorageKey, readBookStatuses, setBookStatus } from "../../lib/book-status-storage";
    import {
      getFavoritePageStorageKey,
      readFavoritePages,
      removePageFavorite,
    } from "../../lib/personal-library";
    import {
      clearReaderNotebook,
      exportReaderNotebook,
      importReaderNotebook,
      listAllReaderNotes,
      removeReaderNote,
    } from "../../lib/reader-storage";
    import { shareContent } from "../../lib/share";

    const searchInput = document.getElementById("notes-search");
    const sortToggleButton = document.getElementById("notes-sort-toggle");
    const sortLabelNode = document.querySelector("[data-notes-sort-label]");
    const exportButton = document.getElementById("notes-export");
    const importButton = document.getElementById("notes-import-trigger");
    const importInput = document.getElementById("notes-import-input");
    const clearButton = document.getElementById("notes-clear");
    const statusNode = document.getElementById("notes-status");
    const summaryNode = document.getElementById("notes-summary");
    const filterStateNodes = Array.from(document.querySelectorAll("[data-notes-filters-state]"));
    const resultsNode = document.getElementById("notes-results");
    const emptyNode = document.getElementById("notes-empty");
    const emptyTitleNode = document.getElementById("notes-empty-title");
    const totalCountNode = document.getElementById("notes-total-count");
    const favoriteBooksCountNode = document.getElementById("favorite-books-count");
    const favoriteBooksInlineCountNode = document.getElementById("favorite-books-inline-count");
    const favoritePagesCountNode = document.getElementById("favorite-pages-count");
    const favoritePagesInlineCountNode = document.getElementById("favorite-pages-inline-count");
    const favoriteBooksResultsNode = document.getElementById("favorite-books-results");
    const favoritePagesResultsNode = document.getElementById("favorite-pages-results");
    const favoriteBooksEmptyNode = document.getElementById("favorite-books-empty");
    const favoritePagesEmptyNode = document.getElementById("favorite-pages-empty");
    const colorButtons = Array.from(document.querySelectorAll("[data-notes-color]"));
    const colorLabels = {
      all: "全部颜色",
      amber: "黄色",
      teal: "青绿",
      rose: "红色",
      violet: "紫色",
    };

    const state = {
      notes: [],
      favoriteBooks: [],
      favoritePages: [],
      query: "",
      sort: "updated-desc",
      color: "all",
      booksById: new Map(),
      pagesById: new Map(),
    };

    function escapeHtml(value) {
      return String(value || "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    function setStatus(message, tone) {
      if (!(statusNode instanceof HTMLElement)) return;
      statusNode.textContent = message;
      statusNode.dataset.tone = tone || "neutral";
    }

    function setBusy(isBusy) {
      [searchInput, exportButton, importButton, clearButton, sortToggleButton].forEach((node) => {
        if (node instanceof HTMLInputElement || node instanceof HTMLButtonElement || node instanceof HTMLSelectElement) {
          node.disabled = isBusy;
        }
      });
    }

    function formatTime(value) {
      if (!value) return "";
      const parsed = new Date(value);
      if (Number.isNaN(parsed.getTime())) return "";
      return new Intl.DateTimeFormat("zh-CN", {
        year: "numeric",
        month: "numeric",
        day: "numeric",
        hour: "2-digit",
        minute: "2-digit",
      }).format(parsed);
    }

    function toNoteMeta(note) {
        const page = state.pagesById.get(note.pageId) || null;
        const book = page ? state.booksById.get(page.book_id) || null : null;
        return {
          pageTitle: page?.title || "原文页面",
          pageUrl: page?.url || "#",
          bookTitle: page?.book_title || book?.title || "未归档书目",
          bookUrl: book?.url || page?.book_url || "#",
          sectionTitle: page?.section_title || book?.section_title || "未分类",
          tags: Array.isArray(page?.tags) ? page.tags : Array.isArray(book?.tags) ? book.tags : [],
        };
    }

    function escapeAttribute(value) {
      return escapeHtml(value).replaceAll("\n", " ");
    }

    function compareByUpdatedAtDesc(left, right) {
      return String(right.updated_at || "").localeCompare(String(left.updated_at || "")) || String(left.title || left.page_title || "").localeCompare(String(right.title || right.page_title || ""));
    }

    function refreshFavorites() {
      const bookStatuses = readBookStatuses();
      state.favoriteBooks = Array.from(state.booksById.values())
        .map((book) => ({
          ...book,
          ...(bookStatuses[book.id] || {}),
        }))
        .filter((book) => book.curation_state === "favorite")
        .sort(compareByUpdatedAtDesc);

      state.favoritePages = Object.values(readFavoritePages())
        .map((favorite) => {
          const page = state.pagesById.get(favorite.page_id);
          const book = favorite.book_id ? state.booksById.get(favorite.book_id) : null;
          return {
            ...favorite,
            page_title: page?.title || favorite.page_title,
            page_url: page?.url || favorite.page_url,
            page_summary: page?.summary || page?.intent || favorite.page_summary,
            book_title: page?.book_title || book?.title || favorite.book_title,
            book_url: book?.url || favorite.book_url,
            section_title: page?.section_title || book?.section_title || favorite.section_title,
            slot: page?.slot || favorite.slot,
          };
        })
        .sort(compareByUpdatedAtDesc);
    }

    function buildSearchText(note, meta) {
      return [
        note.quote,
        note.note,
        meta.pageTitle,
        meta.bookTitle,
        meta.sectionTitle,
        meta.tags.join(" "),
      ].join(" ").toLowerCase();
    }

    function compareNotes(left, right) {
      const leftUpdated = String(left.updatedAt || "");
      const rightUpdated = String(right.updatedAt || "");
      if (state.sort === "updated-asc") return leftUpdated.localeCompare(rightUpdated) || left.id.localeCompare(right.id);
      return rightUpdated.localeCompare(leftUpdated) || right.id.localeCompare(left.id);
    }

    function getFilteredNotes() {
      const query = state.query.trim().toLowerCase();
      return state.notes
        .slice()
        .filter((note) => {
          if (state.color !== "all" && note.color !== state.color) return false;
          if (query && !buildSearchText(note, toNoteMeta(note)).includes(query)) return false;
          return true;
        })
        .sort(compareNotes);
    }

    function renderStats() {
      if (totalCountNode) totalCountNode.textContent = String(state.notes.length);
      if (favoriteBooksCountNode) favoriteBooksCountNode.textContent = String(state.favoriteBooks.length);
      if (favoriteBooksInlineCountNode) {
        favoriteBooksInlineCountNode.textContent = state.favoriteBooks.length + " 本";
      }
      if (favoritePagesCountNode) favoritePagesCountNode.textContent = String(state.favoritePages.length);
      if (favoritePagesInlineCountNode) {
        favoritePagesInlineCountNode.textContent = state.favoritePages.length + " 篇";
      }
    }

    function renderFavoriteCollections() {
      if (favoriteBooksResultsNode instanceof HTMLElement) {
        if (!state.favoriteBooks.length) {
          favoriteBooksResultsNode.innerHTML = "";
          if (favoriteBooksEmptyNode instanceof HTMLElement) favoriteBooksEmptyNode.hidden = false;
        } else {
          if (favoriteBooksEmptyNode instanceof HTMLElement) favoriteBooksEmptyNode.hidden = true;
          favoriteBooksResultsNode.innerHTML = state.favoriteBooks
            .map((book) => `
              <article class="personal-card">
                <div class="personal-card-topline">
                  <span class="meta-chip">${escapeHtml(book.section_title || "未分类")}</span>
                  <span class="meta-chip">书</span>
                </div>
                <h3>${escapeHtml(book.title)}</h3>
                <p>${escapeHtml(book.summary || "这本书目前还没有摘要。")}</p>
                <div class="personal-card-actions">
                  <a class="tool-switch tool-switch--compact" href="${escapeAttribute(book.url || "#")}">打开这本书</a>
                  <button class="tool-switch tool-switch--compact" type="button" data-personal-book-unfavorite="${escapeAttribute(book.id)}">取消收藏</button>
                </div>
              </article>
            `)
            .join("");
        }
      }

      if (favoritePagesResultsNode instanceof HTMLElement) {
        if (!state.favoritePages.length) {
          favoritePagesResultsNode.innerHTML = "";
          if (favoritePagesEmptyNode instanceof HTMLElement) favoritePagesEmptyNode.hidden = false;
        } else {
          if (favoritePagesEmptyNode instanceof HTMLElement) favoritePagesEmptyNode.hidden = true;
          favoritePagesResultsNode.innerHTML = state.favoritePages
            .map((page) => `
              <article class="personal-card personal-card--page">
                <div class="personal-card-topline">
                  <span class="meta-chip">${escapeHtml(page.slot || "--")}</span>
                  <span class="meta-chip">${escapeHtml(page.book_title || "未归档书目")}</span>
                </div>
                <h3>${escapeHtml(page.page_title)}</h3>
                <p>${escapeHtml(page.page_summary || "这篇文章目前还没有摘要。")}</p>
                <div class="personal-card-actions">
                  <a class="tool-switch tool-switch--compact" href="${escapeAttribute(page.page_url || "#")}">打开文章</a>
                  ${page.book_url ? `<a class="tool-switch tool-switch--compact" href="${escapeAttribute(page.book_url)}">回到这本书</a>` : ""}
                  <button class="tool-switch tool-switch--compact" type="button" data-personal-page-unfavorite="${escapeAttribute(page.page_id)}">取消收藏</button>
                </div>
              </article>
            `)
            .join("");
        }
      }
    }

    function renderFilterState(visibleCount) {
      if (sortToggleButton instanceof HTMLButtonElement) {
        const isAscending = state.sort === "updated-asc";
        sortToggleButton.classList.toggle("is-ascending", isAscending);
        const currentLabel = isAscending ? "最早" : "最近";
        sortToggleButton.setAttribute("aria-label", "当前按" + currentLabel + "更新排序");
        sortToggleButton.setAttribute("title", "当前按" + currentLabel + "更新排序");
        if (sortLabelNode instanceof HTMLElement) sortLabelNode.textContent = currentLabel;
      }

      colorButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        const isActive = button.dataset.notesColor === state.color;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", isActive ? "true" : "false");
      });

      if (!state.notes.length) {
        if (summaryNode instanceof HTMLElement) {
          summaryNode.textContent = "还没有笔记。";
        }
        filterStateNodes.forEach((node) => {
          if (node instanceof HTMLElement) node.textContent = "";
        });
        return;
      }

      const labels = [];
      if (state.color !== "all") labels.push(colorLabels[state.color] || "已筛颜色");
      if (state.query) labels.push("搜索中");
      if (summaryNode instanceof HTMLElement) {
        const countText = visibleCount === state.notes.length ? "共 " + state.notes.length + " 条。" : "已筛到 " + visibleCount + " / " + state.notes.length + " 条。";
        summaryNode.textContent = countText + (labels.length ? " " + labels.join(" · ") : "");
      }
      filterStateNodes.forEach((node) => {
        if (node instanceof HTMLElement) node.textContent = labels.join(" · ");
      });
    }

    function renderEmpty(title, message) {
      if (resultsNode) resultsNode.innerHTML = "";
      if (emptyNode instanceof HTMLElement) {
        emptyNode.hidden = false;
        if (emptyTitleNode instanceof HTMLElement && title) {
          emptyTitleNode.textContent = title;
        }
        const paragraph = emptyNode.querySelector("p");
        if (paragraph && message) paragraph.textContent = message;
      }
    }

    function render() {
      renderStats();
      renderFavoriteCollections();
      if (!(resultsNode instanceof HTMLElement)) return;

      const visible = getFilteredNotes();
      renderFilterState(visible.length);

      if (!state.notes.length) {
        renderEmpty("还没有本地笔记", "去任意一篇正文里划一段，或者导入你之前备份过的笔记。");
        return;
      }

      if (!visible.length) {
        renderEmpty("没有符合条件的笔记", "没搜到匹配项。换个词，或者先清掉一个条件。");
        return;
      }

      if (emptyNode instanceof HTMLElement) {
        emptyNode.hidden = true;
      }

      const groups = new Map();
      visible.forEach((note) => {
        const meta = toNoteMeta(note);
        const page = state.pagesById.get(note.pageId);
        const key = page?.book_id || note.pageId;
        const group = groups.get(key) || {
          key,
          bookTitle: meta.bookTitle,
          bookUrl: meta.bookUrl,
          sectionTitle: meta.sectionTitle,
          notes: [],
        };
        group.notes.push({ note, meta });
        groups.set(key, group);
      });

      const groupMarkup = Array.from(groups.values())
        .sort((left, right) => compareNotes(left.notes[0].note, right.notes[0].note))
        .map((group) => {
          const items = group.notes
            .map(({ note, meta }) => {
              const noteCopy = String(note.note || "").trim();
              return `
                <article class="notes-note-card notes-note-card--${escapeHtml(note.color || "amber")}">
                  <div class="notes-note-topline">
                    <p class="notes-note-page">
                      <span class="notes-note-color-dot notes-note-color-dot--${escapeHtml(note.color || "amber")}" aria-hidden="true"></span>
                      <span>${escapeHtml(meta.pageTitle)}</span>
                    </p>
                    <time class="notes-note-time" datetime="${escapeHtml(note.updatedAt)}">${escapeHtml(formatTime(note.updatedAt))}</time>
                  </div>
                  <p class="notes-note-quote">${escapeHtml(note.quote)}</p>
                  <p class="notes-note-copy${noteCopy ? "" : " notes-note-copy--muted"}">${escapeHtml(noteCopy || "只划线，没写备注。")}</p>
                  <div class="notes-note-actions">
                    <a class="tool-switch tool-switch--compact" href="${escapeHtml(meta.pageUrl)}">打开原文</a>
                    <button class="tool-switch tool-switch--compact tool-switch--share" type="button" data-note-share="${escapeHtml(note.id)}">
                      <span aria-hidden="true">↗</span>
                      <span>分享</span>
                    </button>
                    <button class="tool-switch tool-switch--compact" type="button" data-note-delete="${escapeHtml(note.id)}">删除</button>
                  </div>
                </article>
              `;
            })
            .join("");
          return `
            <section class="notes-book-group">
              <div class="notes-book-head">
                <div>
                  <p class="eyebrow">${escapeHtml(group.sectionTitle)}</p>
                  <h2>${escapeHtml(group.bookTitle)}</h2>
                </div>
                <div class="notes-book-meta">
                  <span class="meta-chip">${group.notes.length} 条</span>
                  ${group.bookUrl && group.bookUrl !== "#" ? `<a class="tool-switch tool-switch--compact" href="${escapeHtml(group.bookUrl)}">回到这本书</a>` : ""}
                </div>
              </div>
              <div class="notes-book-list">${items}</div>
            </section>
          `;
        })
        .join("");

      resultsNode.innerHTML = groupMarkup;
    }

    async function loadIndex() {
      try {
        const response = await fetch("/data/site-content.json", { cache: "force-cache" });
        if (!response.ok) throw new Error("Failed to load site content");
        const payload = await response.json();
        const books = Array.isArray(payload.books) ? payload.books : [];
        const pages = Array.isArray(payload.pages) ? payload.pages : [];
        books.forEach((book) => {
          if (book && book.id) state.booksById.set(book.id, book);
        });
        pages.forEach((page) => {
          if (page && page.id) state.pagesById.set(page.id, page);
        });
      } catch (error) {
        console.error("Failed to load notes index", error);
        setStatus("笔记已加载，但原文标题和书名索引暂时没拿到。", "warning");
      } finally {
        refreshFavorites();
      }
    }

    async function refreshNotes() {
      setBusy(true);
      try {
        state.notes = await listAllReaderNotes();
        render();
        if (state.notes.length) {
          setStatus("仅本地保存，导入前先导出。", "neutral");
        } else {
          setStatus("仅本地保存，导入前先导出。", "neutral");
        }
      } catch (error) {
        console.error("Failed to load reader notes", error);
        renderEmpty("笔记读取失败", "笔记读取失败了，刷新后再试一次。");
        setStatus("本地笔记读取失败了。", "danger");
      } finally {
        setBusy(false);
      }
    }

    function downloadExport(payload) {
      const filenameDate = new Date().toISOString().slice(0, 10);
      const blob = new Blob([JSON.stringify(payload, null, 2)], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const anchor = document.createElement("a");
      anchor.href = url;
      anchor.download = "reader-notes-" + filenameDate + ".json";
      document.body.appendChild(anchor);
      anchor.click();
      anchor.remove();
      URL.revokeObjectURL(url);
    }

    async function readImportFile(file) {
      const text = await file.text();
      return JSON.parse(text);
    }

    if (searchInput instanceof HTMLInputElement) {
      searchInput.addEventListener("input", function () {
        state.query = searchInput.value || "";
        render();
      });
    }

    if (sortToggleButton instanceof HTMLButtonElement) {
      sortToggleButton.addEventListener("click", function () {
        state.sort = state.sort === "updated-desc" ? "updated-asc" : "updated-desc";
        render();
      });
    }

    colorButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      button.addEventListener("click", function () {
        state.color = button.dataset.notesColor || "all";
        render();
      });
    });

    if (exportButton instanceof HTMLButtonElement) {
      exportButton.addEventListener("click", async function () {
        setBusy(true);
        try {
          const payload = await exportReaderNotebook();
          downloadExport(payload);
          setStatus("导出完成。可以把这份 JSON 留作备份。", "success");
        } catch (error) {
          console.error("Failed to export reader notes", error);
          setStatus("导出失败了。稍后再试一次。", "danger");
        } finally {
          setBusy(false);
        }
      });
    }

    if (importButton instanceof HTMLButtonElement && importInput instanceof HTMLInputElement) {
      importButton.addEventListener("click", function () {
        importInput.click();
      });

      importInput.addEventListener("change", async function () {
        const file = importInput.files && importInput.files[0];
        if (!file) return;
        setBusy(true);
        try {
          const payload = await readImportFile(file);
          const result = await importReaderNotebook(payload);
          state.notes = Array.isArray(result.notes) ? result.notes : [];
          render();
          setStatus("导入完成，当前浏览器里的本地笔记已经更新。", "success");
        } catch (error) {
          console.error("Failed to import reader notes", error);
          setStatus(error instanceof Error ? error.message : "导入失败了。", "danger");
        } finally {
          importInput.value = "";
          setBusy(false);
        }
      });
    }

    if (clearButton instanceof HTMLButtonElement) {
      clearButton.addEventListener("click", async function () {
        if (!window.confirm("要清空这个浏览器里的全部本地笔记吗？")) return;
        setBusy(true);
        try {
          await clearReaderNotebook();
          state.notes = [];
          render();
          setStatus("当前浏览器里的本地笔记已经清空。", "success");
        } catch (error) {
          console.error("Failed to clear reader notes", error);
          setStatus("清空失败了。稍后再试一次。", "danger");
        } finally {
          setBusy(false);
        }
      });
    }

    if (resultsNode instanceof HTMLElement) {
      resultsNode.addEventListener("click", async function (event) {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const button = target.closest("[data-note-delete]");
        if (button instanceof HTMLElement) {
          const noteId = button.getAttribute("data-note-delete");
          if (!noteId) return;
          if (!window.confirm("要删掉这条本地笔记吗？")) return;
          setBusy(true);
          try {
            await removeReaderNote(noteId);
            state.notes = state.notes.filter((note) => note.id !== noteId);
            render();
            setStatus("这条笔记已经删掉。", "success");
          } catch (error) {
            console.error("Failed to delete reader note", error);
            setStatus("删除失败了。稍后再试一次。", "danger");
          } finally {
            setBusy(false);
          }
          return;
        }

        const shareButton = target.closest("[data-note-share]");
        if (shareButton instanceof HTMLElement) {
          const noteId = shareButton.getAttribute("data-note-share");
          if (!noteId) return;
          const note = state.notes.find((item) => item.id === noteId);
          if (!note) return;
          const meta = toNoteMeta(note);
          const noteCopy = String(note.note || "").trim();
          const shareText = [
            note.quote,
            noteCopy ? "笔记：" + noteCopy : "",
            meta.bookTitle,
            meta.pageTitle,
          ]
            .filter(Boolean)
            .join("\n");

          try {
            const result = await shareContent({
              title: meta.bookTitle + " · " + meta.pageTitle,
              text: shareText,
              url: meta.pageUrl && meta.pageUrl !== "#" ? meta.pageUrl : window.location.href,
            });
            setStatus(result.method === "clipboard" ? "已复制这条笔记的分享内容。" : "已打开分享面板。", "success");
          } catch (error) {
            if (error instanceof DOMException && error.name === "AbortError") return;
            console.error("Failed to share reader note", error);
            setStatus("分享失败了。稍后再试一次。", "danger");
          }
          return;
        }

      });
    }

    if (favoriteBooksResultsNode instanceof HTMLElement) {
      favoriteBooksResultsNode.addEventListener("click", function (event) {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const button = target.closest("[data-personal-book-unfavorite]");
        if (!(button instanceof HTMLElement)) return;
        const bookId = button.getAttribute("data-personal-book-unfavorite");
        if (!bookId) return;
        setBookStatus(bookId, { curation_state: "normal" });
        refreshFavorites();
        render();
        setStatus("这本书已从收藏里移出。", "success");
      });
    }

    if (favoritePagesResultsNode instanceof HTMLElement) {
      favoritePagesResultsNode.addEventListener("click", function (event) {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const button = target.closest("[data-personal-page-unfavorite]");
        if (!(button instanceof HTMLElement)) return;
        const pageId = button.getAttribute("data-personal-page-unfavorite");
        if (!pageId) return;
        removePageFavorite(pageId);
        refreshFavorites();
        render();
        setStatus("这篇文章已从收藏里移出。", "success");
      });
    }

    window.addEventListener("book-status:changed", function () {
      refreshFavorites();
      render();
    });

    window.addEventListener("page-favorite:changed", function () {
      refreshFavorites();
      render();
    });

    window.addEventListener("storage", function (event) {
      if (event.key !== getBookStatusStorageKey() && event.key !== getFavoritePageStorageKey()) return;
      refreshFavorites();
      render();
    });

    Promise.allSettled([loadIndex(), refreshNotes()]).then(function () {
      refreshFavorites();
      render();
    });
  </script>
</BaseLayout>
